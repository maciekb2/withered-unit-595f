POSTGRES_PASSWORD=replace-on-host
PSEUDOINTELEKT_TUNNEL_TOKEN_FILE=/opt/pseudointelekt/secrets/cloudflare-tunnel-token
WORKER_ID=pseudointelekt-selfhosted
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_TOPIC_MODEL=qwen3:latest
OPENAI_OUTLINE_MODEL=qwen3:30b
OPENAI_DRAFT_MODEL=qwen3:30b
OPENAI_EDIT_MODEL=qwen3:30b
OPENAI_REPAIR_MODEL=qwen3:30b
OPENAI_REVIEW_MODEL=gpt-oss:20b
OPENAI_PROOFREAD_MODEL=qwen3:30b
OPENAI_IMAGE_MODEL=gpt-image-2
LOCAL_FINAL_EDIT=true
TEXT_GENERATION_PROVIDER=jetson
TEXT_GENERATION_FALLBACK=openai
JETSON_GATEWAY_URL=http://10.2.11.58:8110
JETSON_GATEWAY_TOKEN=replace-with-helpdesk-gateway-token
JETSON_GATEWAY_MODEL=qwen3:30b
JETSON_GATEWAY_TIMEOUT_MS=540000
JETSON_GATEWAY_DISABLE_THINKING=false
GENERATOR_PRIVATE_TOKEN=replace-with-vault-secret
CF_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com
CF_ACCESS_AUD=replace-with-access-application-audience
SENTRY_TEST_ENDPOINT=disabled
SENTRY_TEST_TOKEN=replace-with-vault-secret
SCHEDULER_ENABLED=true
SCHEDULER_RUN_HOUR=10
SCHEDULER_RUN_MINUTE=0
SCHEDULER_TIME_ZONE=Europe/Warsaw
SCHEDULER_TIMEOUT_MS=900000

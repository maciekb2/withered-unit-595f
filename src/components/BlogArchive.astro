---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import Pagination from './Pagination.astro';

type Post = CollectionEntry<'blog'>;
interface Props { posts: Post[]; page: number; perPage: number; }
const { posts, page, perPage } = Astro.props as Props;
const [featuredPost, ...archivePosts] = posts;
const totalPages = Math.max(1, Math.ceil(archivePosts.length / perPage));
const currentPage = Math.min(Math.max(page, 1), totalPages);
const pagePosts = archivePosts.slice((currentPage - 1) * perPage, currentPage * perPage);
const filters = Array.from(new Set(posts.flatMap((post) => post.data.tags))).sort((a, b) => a.localeCompare(b, 'pl'));
const latestYear = featuredPost?.data.pubDate.getFullYear();
const records = posts.map((post) => ({
  id: post.id, title: post.data.title, description: post.data.description, tags: post.data.tags,
  image: post.data.heroImage, date: post.data.pubDate.toISOString(),
}));
const hrefForPage = (target: number) => target === 1 ? '/blog/' : `/blog/${target}/`;
---

<main class="blog-page">
  <section class="blog-intro" aria-labelledby="blog-title">
    <div class="blog-intro__copy">
      <p class="kicker">Archiwum analiz</p>
      <h1 id="blog-title">Kartoteka interesów</h1>
      <p>Materiały o decyzjach, które zostają po nagłówkach: w portach, budżetach, sieciach i relacjach między państwami.</p>
      <div class="filters-block">
        <p class="filters-label">Wybierz obszar</p>
        <div class="topic-filters" aria-label="Filtruj według tematu">
          <button class="topic-filter" type="button" data-topic-filter="" aria-pressed="true">Wszystkie</button>
          {filters.map((filter) => <button class="topic-filter" type="button" data-topic-filter={filter} aria-pressed="false">{filter.replaceAll('-', ' ')}</button>)}
        </div>
      </div>
    </div>
    <div class="blog-tools">
      <label for="blog-search">Szukaj w całym archiwum
        <input id="blog-search" class="blog-search" type="search" placeholder="Tytuł, temat lub zagadnienie" autocomplete="off" />
      </label>
      <p class="blog-count" data-blog-count>{posts.length} materiałów{latestYear ? ` · archiwum ${latestYear}` : ''}</p>
      <button class="clear-search" type="button" data-clear-search hidden>Wyczyść wyszukiwanie</button>
    </div>
  </section>

  <div data-default-archive>
    {currentPage === 1 && featuredPost && (
      <section class="featured" aria-label="Najnowszy materiał">
        <a class="featured-link" href={`/blog/${featuredPost.id}/`}>
          <div class="featured-media">{featuredPost.data.heroImage && <img width="960" height="540" src={featuredPost.data.heroImage} alt="" loading="eager" />}</div>
          <div class="featured-body"><p class="post-meta"><span class="marker">Najnowsza analiza</span><span>{featuredPost.data.tags[0]}</span><span><FormattedDate date={featuredPost.data.pubDate} /></span></p><h2>{featuredPost.data.title}</h2><p>{featuredPost.data.description}</p></div>
        </a>
      </section>
    )}
    <section aria-label={`Archiwum, strona ${currentPage}`}>
      <ul class="post-list">
        {pagePosts.map((post) => <li class="post-card"><a href={`/blog/${post.id}/`}><div class="post-card-media">{post.data.heroImage && <img width="720" height="480" src={post.data.heroImage} alt="" loading="lazy" />}</div><div class="post-card-body"><p class="post-meta"><span>{post.data.tags[0]}</span><span><FormattedDate date={post.data.pubDate} /></span></p><h2>{post.data.title}</h2><p>{post.data.description}</p></div></a></li>)}
      </ul>
      <Pagination currentPage={currentPage} totalPages={totalPages} hrefForPage={hrefForPage} label="Strony archiwum" />
    </section>
  </div>

  <section class="search-results" aria-live="polite" hidden data-search-results>
    <header><div><p class="kicker">Wyniki archiwum</p><h2 data-results-title>Wyniki wyszukiwania</h2></div><p data-results-count></p></header>
    <ul class="post-list" data-results-list></ul>
    <nav class="pagination" aria-label="Strony wyników" data-results-pagination></nav>
    <p class="empty-results" data-empty-results hidden>Nie znaleźliśmy materiałów dla tego zapytania. Spróbuj krótszej frazy lub innego tematu.</p>
  </section>
</main>

<script define:vars={{ records, perPage }}>
  const search = document.querySelector('#blog-search');
  const filters = Array.from(document.querySelectorAll('[data-topic-filter]'));
  const defaultArchive = document.querySelector('[data-default-archive]');
  const results = document.querySelector('[data-search-results]');
  const list = document.querySelector('[data-results-list]');
  const pagination = document.querySelector('[data-results-pagination]');
  const count = document.querySelector('[data-results-count]');
  const empty = document.querySelector('[data-empty-results]');
  const clear = document.querySelector('[data-clear-search]');
  const normalCount = document.querySelector('[data-blog-count]');
  let activeTopic = new URLSearchParams(location.search).get('temat') || '';
  let resultPage = 1;
  let timer = 0;
  let lastQuery = '';
  if (search instanceof HTMLInputElement) search.value = new URLSearchParams(location.search).get('q') || '';

  function card(post) {
    const item = document.createElement('li'); item.className = 'post-card';
    const link = document.createElement('a'); link.href = `/blog/${post.id}/`;
    const media = document.createElement('div'); media.className = 'post-card-media';
    if (post.image) { const image = document.createElement('img'); image.src = post.image; image.alt = ''; image.loading = 'lazy'; media.append(image); }
    const body = document.createElement('div'); body.className = 'post-card-body';
    const meta = document.createElement('p'); meta.className = 'post-meta';
    const tag = document.createElement('span'); tag.textContent = post.tags[0] || 'analiza';
    const date = document.createElement('span'); date.textContent = new Intl.DateTimeFormat('pl-PL', { day:'2-digit', month:'long', year:'numeric' }).format(new Date(post.date));
    meta.append(tag, date);
    const title = document.createElement('h2'); title.textContent = post.title;
    const description = document.createElement('p'); description.textContent = post.description;
    body.append(meta, title, description); link.append(media, body); item.append(link); return item;
  }
  function setFilters() { filters.forEach((button) => button.setAttribute('aria-pressed', String(button.dataset.topicFilter === activeTopic))); }
  function updateUrl(query) { const params = new URLSearchParams(); if (query) params.set('q', query); if (activeTopic) params.set('temat', activeTopic); history.replaceState({}, '', `${location.pathname}${params.size ? `?${params}` : ''}`); }
  function render(targetPage = 1) {
    const query = search instanceof HTMLInputElement ? search.value.trim().toLocaleLowerCase('pl-PL') : '';
    const filtered = records.filter((post) => (!query || `${post.title} ${post.description} ${post.tags.join(' ')}`.toLocaleLowerCase('pl-PL').includes(query)) && (!activeTopic || post.tags.includes(activeTopic)));
    const active = Boolean(query || activeTopic); resultPage = targetPage;
    if (defaultArchive) defaultArchive.hidden = active;
    if (results) results.hidden = !active;
    if (clear instanceof HTMLButtonElement) clear.hidden = !active;
    if (normalCount && !active) normalCount.textContent = `${records.length} materiałów · pełne archiwum`;
    if (!active || !list || !pagination || !count || !empty) return;
    const pages = Math.max(1, Math.ceil(filtered.length / perPage)); resultPage = Math.min(resultPage, pages);
    list.replaceChildren(...filtered.slice((resultPage - 1) * perPage, resultPage * perPage).map(card));
    count.textContent = `${filtered.length} ${filtered.length === 1 ? 'materiał' : 'materiałów'}${activeTopic ? ` · ${activeTopic.replaceAll('-', ' ')}` : ''}`;
    empty.hidden = filtered.length !== 0;
    pagination.replaceChildren();
    if (pages > 1) {
      const addControl = (label, page, disabled = false) => { const button = document.createElement('button'); button.type = 'button'; button.className = 'pagination-control'; button.textContent = label; button.disabled = disabled; button.addEventListener('click', () => render(page)); pagination.append(button); };
      addControl('← Nowsze', resultPage - 1, resultPage === 1);
      const numbers = document.createElement('ol');
      for (let number = 1; number <= pages; number += 1) { const item = document.createElement('li'); const button = document.createElement('button'); button.type = 'button'; button.className = 'pagination-number'; button.textContent = String(number); button.setAttribute('aria-label', `Strona wyników ${number}`); if (number === resultPage) button.setAttribute('aria-current', 'page'); button.addEventListener('click', () => render(number)); item.append(button); numbers.append(item); }
      pagination.append(numbers);
      addControl('Starsze →', resultPage + 1, resultPage === pages);
    }
    updateUrl(query); setFilters();
    clearTimeout(timer); if (query.length >= 2 && query !== lastQuery) { timer = setTimeout(() => { lastQuery = query; window.pseudointelektTrack?.('blog_search', { query_length: query.length, result_count: filtered.length, topic: activeTopic || 'all', result_page: resultPage }); }, 500); }
  }
  filters.forEach((button) => button.addEventListener('click', () => { activeTopic = button.dataset.topicFilter || ''; render(); }));
  search?.addEventListener('input', () => render());
  clear?.addEventListener('click', () => { if (search instanceof HTMLInputElement) search.value = ''; activeTopic = ''; render(); });
  setFilters(); if ((search instanceof HTMLInputElement && search.value) || activeTopic) render();
</script>

<style>

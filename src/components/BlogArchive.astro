02,118,.22);border-radius:12px;color:inherit;background:rgba(7,43,33,.8);text-decoration:none}.featured-media{aspect-ratio:3/2;background:#0b3329}.featured-media img,.post-card-media img{display:block;width:100%;height:100%;object-fit:cover;filter:saturate(.84) contrast(1.04)}.featured-body{display:grid;align-content:center;padding:clamp(1.25rem,3vw,2.25rem)}.post-meta{display:flex;flex-wrap:wrap;gap:.55rem;margin:0;color:var(--gold-accent);font-size:.74rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase}.marker{padding:.2rem .45rem;border:1px solid rgba(224,202,118,.35);border-radius:999px}.featured h2{margin:.85rem 0;color:var(--ivory);font-size:clamp(1.8rem,3.5vw,3rem);line-height:1.05}.featured p:last-child,.post-card-body>p:last-child{margin:0;color:rgba(241,238,229,.72);font-size:.94rem;line-height:1.55}.post-list{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.9rem;margin:0;padding:0;list-style:none}.post-card a{display:grid;height:100%;overflow:hidden;border:1px solid rgba(224,202,118,.18);border-radius:12px;color:inherit;background:rgba(7,43,33,.78);text-decoration:none}.post-card-media{aspect-ratio:3/2;background:#0b3329}.post-card-body{display:grid;align-content:start;gap:.72rem;padding:1.05rem;background:rgba(5,37,29,.97)}.post-card h2{margin:0;color:var(--ivory);font-size:clamp(1.15rem,2.1vw,1.42rem);line-height:1.12}.post-card a:hover,.post-card a:focus-visible,.featured-link:hover,.featured-link:focus-visible{border-color:var(--gold-accent);box-shadow:0 16px 34px rgba(0,0,0,.22);transform:translateY(-2px);outline:none}.search-results{padding-top:2rem}.search-results header{display:flex;align-items:end;justify-content:space-between;gap:1rem;margin-bottom:1.2rem}.search-results h2{font-size:clamp(2rem,4vw,3.5rem)}.search-results header>p:last-child{margin:0;color:rgba(241,238,229,.68);font-size:.9rem}.empty-results{padding:1rem;border:1px dashed rgba(224,202,118,.35);color:rgba(241,238,229,.75)}[data-results-pagination]{justify-content:center}.pagination button{display:grid;place-items:center;min-width:2.25rem;min-height:2.25rem;padding:.25rem;border:1px solid rgba(224,202,118,.18);background:transparent;color:rgba(241,238,229,.75);font:inherit;cursor:pointer}.pagination button[aria-current=page],.pagination button:hover{color:#072b21;border-color:var(--gold-accent);background:var(--gold-accent)}@media(max-width:880px){.blog-intro,.featured-link{grid-template-columns:1fr}.blog-tools{max-width:none}.featured-media{max-height:390px}}@media(max-width:620px){.blog-page{width:min(100% - 1rem,1180px);padding-top:1.3rem}.post-list{grid-template-columns:1fr}.topic-filters{max-height:112px;overflow:auto}.search-results header{display:grid;align-items:start}}
</style>

<style is:global>
  /* Dynamic search controls are created after Astro scopes component CSS. Keep this block global but strictly limited to the archive. */
  .blog-page .blog-intro { display:grid; grid-template-columns:minmax(0,1fr) minmax(300px,390px); gap:clamp(1.75rem,5vw,4rem); align-items:end; padding:0 0 2.15rem; border-bottom:1px solid rgba(224,202,118,.2); }
  .blog-page .kicker, .blog-page .filters-label { margin:0; color:var(--gold-accent); font-size:.74rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; }
  .blog-page .blog-intro h1, .blog-page .search-results h2 { margin:.65rem 0 0; color:var(--ivory); font-size:clamp(2.7rem,6vw,5.2rem); line-height:.94; }
  .blog-page .blog-intro__copy > p:not(.kicker) { max-width:57ch; margin:1rem 0 0; color:rgba(241,238,229,.74); line-height:1.55; }
  .blog-page .filters-block { display:grid; gap:.6rem; margin-top:1.5rem; }
  .blog-page .topic-filters { display:flex; flex-wrap:wrap; gap:.55rem; }
  .blog-page .topic-filter, .blog-page .clear-search { min-height:2.45rem; padding:.5rem .78rem; border:1px solid rgba(224,202,118,.25); border-radius:999px; background:rgba(3,29,22,.5); color:rgba(241,238,229,.82); font:inherit; font-size:.8rem; font-weight:700; line-height:1.2; cursor:pointer; }
  .blog-page .topic-filter:hover, .blog-page .topic-filter[aria-pressed=true], .blog-page .clear-search:hover { border-color:var(--gold-accent); background:rgba(217,181,62,.16); color:var(--ivory); }
  .blog-page .blog-tools { display:grid; gap:.9rem; padding:1.15rem; border:1px solid rgba(224,202,118,.24); border-radius:12px; background:linear-gradient(145deg,rgba(9,52,39,.92),rgba(3,29,22,.88)); box-shadow:0 18px 36px rgba(0,0,0,.18); }
  .blog-page .blog-tools label { display:grid; gap:.55rem; color:var(--gold-accent); font-size:.78rem; font-weight:700; letter-spacing:.08em; line-height:1.25; text-transform:uppercase; }
  .blog-page .blog-search { min-height:50px; padding:.75rem .9rem; border:1px solid rgba(224,202,118,.3); border-radius:8px; background:rgba(2,24,18,.92); color:var(--ivory); font:inherit; font-size:1rem; line-height:1.35; }
  .blog-page .blog-search:focus { outline:3px solid rgba(217,181,62,.26); border-color:var(--gold-accent); }
  .blog-page .blog-count { margin:0; color:rgba(241,238,229,.66); font-size:.9rem; line-height:1.45; }
  .blog-page .clear-search { justify-self:start; border-color:transparent; background:transparent; color:rgba(241,238,229,.72); }
  .blog-page .featured { margin:2.25rem 0; } .blog-page .featured-link { display:grid; grid-template-columns:minmax(280px,.9fr) minmax(0,1.1fr); overflow:hidden; border:1px solid rgba(224,202,118,.22); border-radius:12px; color:inherit; background:rgba(7,43,33,.8); text-decoration:none; }
  .blog-page .featured-media,.blog-page .post-card-media { aspect-ratio:3/2; background:#0b3329; } .blog-page .featured-media img,.blog-page .post-card-media img { display:block; width:100%; height:100%; object-fit:cover; filter:saturate(.84) contrast(1.04); }
  .blog-page .featured-body { display:grid; align-content:center; gap:.9rem; padding:clamp(1.35rem,3vw,2.25rem); }.blog-page .post-meta { display:flex; flex-wrap:wrap; gap:.5rem .75rem; margin:0; color:var(--gold-accent); font-size:.74rem; font-weight:700; letter-spacing:.05em; line-height:1.35; text-transform:uppercase; }.blog-page .post-meta span + span::before { content:'·'; margin-right:.75rem; color:rgba(241,238,229,.38); }.blog-page .marker{padding:.2rem .45rem;border:1px solid rgba(224,202,118,.35);border-radius:999px}.blog-page .featured h2{margin:0;color:var(--ivory);font-size:clamp(1.8rem,3.5vw,3rem);line-height:1.05}.blog-page .featured p:last-child,.blog-page .post-card-body>p:last-child{margin:0;color:rgba(241,238,229,.72);font-size:.94rem;line-height:1.55}
  .blog-page .post-list{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem;margin:0;padding:0;list-style:none}.blog-page .post-card a{display:grid;height:100%;overflow:hidden;border:1px solid rgba(224,202,118,.18);border-radius:12px;color:inherit;background:rgba(7,43,33,.78);text-decoration:none}.blog-page .post-card-body{display:grid;align-content:start;gap:.8rem;padding:1.15rem;background:rgba(5,37,29,.97)}.blog-page .post-card h2{margin:0;color:var(--ivory);font-size:clamp(1.15rem,2.1vw,1.42rem);line-height:1.16}.blog-page .post-card a:hover,.blog-page .post-card a:focus-visible,.blog-page .featured-link:hover,.blog-page .featured-link:focus-visible{border-color:var(--gold-accent);box-shadow:0 16px 34px rgba(0,0,0,.22);transform:translateY(-2px);outline:none}
  .blog-page .search-results{padding-top:2.5rem}.blog-page .search-results header{display:flex;align-items:end;justify-content:space-between;gap:1.25rem;margin-bottom:1.35rem;padding-bottom:1.1rem;border-bottom:1px solid rgba(224,202,118,.18)}.blog-page .search-results h2{font-size:clamp(2rem,4vw,3.5rem)}.blog-page .search-results header>p:last-child{margin:0;padding:.45rem .65rem;border:1px solid rgba(224,202,118,.18);border-radius:999px;color:rgba(241,238,229,.76);font-size:.86rem;line-height:1.3}.blog-page .empty-results{margin:1.25rem 0 0;padding:1.1rem;border:1px dashed rgba(224,202,118,.35);border-radius:10px;color:rgba(241,238,229,.75)}
  .blog-page .pagination{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin:2.2rem 0 0;padding-top:1.25rem;border-top:1px solid rgba(224,202,118,.22);font-size:.84rem}.blog-page .pagination ol{display:flex;flex-wrap:wrap;justify-content:center;gap:.4rem;margin:0;padding:0;list-style:none}.blog-page .pagination a,.blog-page .pagination button{display:grid;place-items:center;min-width:2.5rem;min-height:2.5rem;padding:.4rem .65rem;border:1px solid rgba(224,202,118,.22);border-radius:7px;background:rgba(3,29,22,.45);color:rgba(241,238,229,.82);font:inherit;font-weight:700;line-height:1;cursor:pointer;text-decoration:none}.blog-page .pagination>a,.blog-page .pagination>span,.blog-page .pagination .pagination-control{min-width:6.4rem}.blog-page .pagination>a:last-child,.blog-page .pagination>span:last-child{text-align:right}.blog-page .pagination>span{display:grid;place-items:center;min-width:6.4rem;min-height:2.5rem;color:rgba(241,238,229,.35)}.blog-page .pagination a:hover,.blog-page .pagination a:focus-visible,.blog-page .pagination button:hover:not(:disabled),.blog-page .pagination button:focus-visible,.blog-page .pagination a[aria-current=page],.blog-page .pagination button[aria-current=page]{border-color:var(--gold-accent);background:var(--gold-accent);color:#072b21;outline:none}.blog-page .pagination button:disabled{opacity:.36;cursor:not-allowed}.blog-page [data-results-pagination]{justify-content:center}.blog-page [data-results-pagination] .pagination-control:first-child{justify-self:start}.blog-page [data-results-pagination] .pagination-control:last-child{justify-self:end}
  @media(max-width:880px){.blog-page .blog-intro,.blog-page .featured-link{grid-template-columns:1fr}.blog-page .featured-media{max-height:390px}}@media(max-width:620px){.blog-page{width:min(100% - 1rem,1180px);padding-top:1.3rem}.blog-page .post-list{grid-template-columns:1fr}.blog-page .topic-filters{max-height:138px;overflow:auto;padding-right:.25rem}.blog-page .search-results header{display:grid;align-items:start}.blog-page .pagination{gap:.55rem;font-size:.74rem}.blog-page .pagination>a,.blog-page .pagination>span,.blog-page .pagination .pagination-control{min-width:auto}.blog-page .pagination a,.blog-page .pagination button{min-width:2.1rem;min-height:2.25rem;padding:.35rem .48rem}.blog-page .pagination .pagination-control{padding-inline:.6rem}}
</style>

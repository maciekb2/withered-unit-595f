---
import { SITE_TITLE } from '../consts';
import Menu from './Menu.astro';
---

<header data-site-header>
        <nav>
                <a href="/" class="logo">
                        <img src="/pseudointelekt_logo_tekstura.svg" alt={SITE_TITLE} />
                </a>
                <Menu />
        </nav>
</header>
<script>
        const header = document.querySelector('header[data-site-header]');

        function updateHeaderState() {
                if (!header) return;
                header.classList.toggle('is-scrolled', window.scrollY > 8);
        }

        updateHeaderState();
        window.addEventListener('scroll', updateHeaderState, { passive: true });
</script>
<style>
        header {
                margin: 0;
                padding: 0 0.75rem;
                background: rgba(248, 246, 241, 0.92);
                border-bottom: 1px solid transparent;
                box-shadow: 0 2px 8px rgba(var(--gray-dark), 8%);
                position: sticky;
                top: 0;
                z-index: 100;
                transition: background-color 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
                min-height: 78px;
                display: flex;
                align-items: center;
                backdrop-filter: blur(8px);
        }
        header.is-scrolled {
                background: rgba(248, 246, 241, 0.98);
                border-bottom-color: rgba(var(--gray-dark), 16%);
                box-shadow: 0 10px 24px rgba(var(--gray-dark), 14%);
        }
        .logo {
                flex: 0 0 auto;
                display: flex;
                align-items: center;
                padding: 0;
                height: 64px;
                min-width: 0;
        }
        .logo img {
                display: block;
                height: 100%;
                width: auto;
                max-width: min(340px, 48vw);
        }
        nav {
                display: flex;
                align-items: center;
                justify-content: space-between;
                width: min(1180px, 100%);
                min-height: 78px;
                margin: 0 auto;
                gap: clamp(1rem, 2.8vw, 2.25rem);
                min-width: 0;
        }
        nav a {
                position: relative;
                border-radius: 999px;
                padding: 0.46rem 0.78rem;
                color: var(--black);
                text-decoration: none;
                transition: color 160ms ease, background 160ms ease, box-shadow 160ms ease;
                display: inline-flex;
                align-items: center;
                min-height: 38px;
                line-height: 1;
                white-space: nowrap;
        }
        nav a:hover:not(.logo) {
                color: var(--accent-dark);
                background: rgba(203, 161, 53, 0.16);
                box-shadow: inset 0 0 0 1px rgba(203, 161, 53, 0.42);
        }
        nav a.active {
                text-decoration: none;
                color: var(--ivory);
                background: var(--diplomatic-blue);
                box-shadow: 0 8px 18px rgba(28, 61, 90, 0.18);
        }

        @media (max-width: 760px) {
                header {
                        padding: 0 0.55rem;
                        min-height: 124px;
                        align-items: stretch;
                }

                nav {
                        min-height: 124px;
                        flex-direction: column;
                        align-items: stretch;
                        justify-content: center;
                        gap: 0.5rem;
                        padding: 0.45rem 0 0.55rem;
                }

                .logo {
                        height: 58px;
                        justify-content: center;
                }

                .logo img {
                        max-width: min(340px, 88vw);
                }

                nav a {
                        min-height: 36px;
                        padding: 0.42rem 0.7rem;
                        font-size: 0.88rem;
                }
        }

        @media (max-width: 420px) {
                header {
                        min-height: 118px;
                }

                nav {
                        min-height: 118px;
                }

                .logo {
                        height: 52px;
                }

                nav a {
                        font-size: 0.82rem;
                        padding: 0.38rem 0.62rem;
                }
        }
</style>

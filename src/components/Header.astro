---
import { SITE_TITLE } from '../consts';
import Menu from './Menu.astro';
---

<header data-site-header>
        <nav>
                <a href="/" class="logo">
                        <img src="/pseudointelekt_logo_tekstura.svg" alt={SITE_TITLE} />
                </a>
                <Menu />
        </nav>
</header>
<script>
        const header = document.querySelector('header[data-site-header]');

        function updateHeaderState() {
                if (!header) return;
                header.classList.toggle('is-scrolled', window.scrollY > 8);
        }

        updateHeaderState();
        window.addEventListener('scroll', updateHeaderState, { passive: true });
</script>
<style>
        header {
                margin: 0;
                padding: 0 1em;
                background: rgba(var(--gray-light), 94%);
                border-bottom: 1px solid transparent;
                box-shadow: 0 2px 8px rgba(var(--gray-dark), 8%);
                position: sticky;
                top: 0;
                z-index: 100;
                transition: background-color 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
                min-height: 72px;
                display: flex;
                align-items: center;
                backdrop-filter: blur(8px);
        }
        header.is-scrolled {
                background: rgba(var(--gray-light), 98%);
                border-bottom-color: rgba(var(--gray-dark), 16%);
                box-shadow: 0 10px 24px rgba(var(--gray-dark), 14%);
        }
        .logo {
                display: flex;
                align-items: center;
                padding: 0;
                height: 56px;
        }
        .logo img {
                display: block;
                height: 100%;
                width: auto;
        }
        nav {
                display: flex;
                align-items: center;
                justify-content: space-between;
                width: min(1100px, 100%);
                min-height: 72px;
                margin: 0 auto;
        }
        nav a {
                position: relative;
                padding: 0 0.75em;
                color: var(--black);
                text-decoration: none;
                transition: color 0.3s, transform 0.2s;
                display: flex;
                align-items: center;
                height: 100%;
        }
        nav a:hover:not(.logo) {
                color: var(--accent);
                box-shadow: inset 0 0 0 2px var(--accent);
                transform: scale(1.05);
        }
        nav a.active {
                text-decoration: none;
                box-shadow: inset 0 0 0 2px var(--accent);
        }

</style>

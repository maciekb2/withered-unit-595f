---
import '@fontsource-variable/archivo/wght.css';
import { SITE_TITLE } from '../consts';
import Menu from './Menu.astro';

interface Props {
        overlay?: boolean;
}

const { overlay = false } = Astro.props as Props;
---

<header data-site-header data-overlay={overlay ? 'true' : 'false'}>
        <nav aria-label="Główna nawigacja">
                <a href="/" class="logo" aria-label={`${SITE_TITLE} — strona główna`}>
                        <img src="/pseudointelekt_logo_tekstura.svg" alt="" width="620" height="115" />
                </a>
                <button
                        class="menu-toggle"
                        type="button"
                        aria-expanded="false"
                        aria-controls="site-menu"
                        data-menu-toggle
                >
                        <span class="menu-toggle-label">Menu</span>
                        <span class="menu-toggle-icon" aria-hidden="true"><i></i><i></i></span>
                </button>
                <Menu />
        </nav>
</header>

<script>
        document.querySelectorAll<HTMLElement>('header[data-site-header]').forEach((header) => {
                const toggle = header.querySelector<HTMLButtonElement>('[data-menu-toggle]');
                const menu = header.querySelector<HTMLElement>('#site-menu');

                const closeMenu = () => {
                        header.classList.remove('menu-open');
                        toggle?.setAttribute('aria-expanded', 'false');
                };

                const updateHeaderState = () => {
                        header.classList.toggle('is-scrolled', window.scrollY > 12);
                };

                toggle?.addEventListener('click', () => {
                        const willOpen = !header.classList.contains('menu-open');
                        header.classList.toggle('menu-open', willOpen);
                        toggle.setAttribute('aria-expanded', String(willOpen));
                });

                menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
                document.addEventListener('keydown', (event) => {
                        if (event.key === 'Escape') {
                                closeMenu();
                                toggle?.focus();
                        }
                });
                document.addEventListener('pointerdown', (event) => {
                        if (event.target instanceof Node && !header.contains(event.target)) closeMenu();
                });
                window.addEventListener('resize', () => {
                        if (window.innerWidth > 760) closeMenu();
                }, { passive: true });
                window.addEventListener('scroll', updateHeaderState, { passive: true });
                updateHeaderState();
        });
</script>

<style>
        header {
                position: sticky;
                top: 0;
                z-index: 100;
                width: 100%;
                min-height: 76px;
                padding: 0 1.25rem;
                display: flex;
                align-items: center;
                border-bottom: 1px solid rgba(28, 61, 90, 0.1);
                background: rgba(248, 246, 241, 0.93);
                box-shadow: 0 6px 24px rgba(9, 31, 25, 0.08);
                backdrop-filter: blur(16px);
                transition: min-height 220ms ease, background 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
        }

        header[data-overlay="true"] {
                position: fixed;
                border-bottom-color: rgba(235, 222, 171, 0.1);
                background: linear-gradient(180deg, rgba(3, 20, 16, 0.76), rgba(3, 20, 16, 0.24));
                box-shadow: none;
        }

        header.is-scrolled,
        header[data-overlay="true"].is-scrolled,
        header.menu-open {
                min-height: 68px;
                border-bottom-color: rgba(205, 180, 81, 0.18);
                background: rgba(4, 28, 22, 0.94);
                box-shadow: 0 12px 34px rgba(1, 13, 10, 0.24);
        }

        nav {
                position: relative;
                width: min(1180px, 100%);
                min-height: inherit;
                margin: 0 auto;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 2rem;
        }

        .logo {
                flex: 0 0 auto;
                width: min(246px, 36vw);
                height: 56px;
                padding: 0;
                display: flex;
                align-items: center;
                border-radius: 0;
        }

        .logo img {
                display: block;
                width: 100%;
                height: 100%;
                object-fit: contain;
                border-radius: 0;
                filter: sepia(0.1) saturate(1.08);
        }

        :global(header[data-site-header] nav a:not(.logo)) {
                position: relative;
                min-height: 42px;
                padding: 0.55rem 0.2rem;
                display: inline-flex;
                align-items: center;
                border-radius: 0;
                color: #173a32;
                font-family: "Archivo Variable", "Atkinson", sans-serif;
                font-size: 0.78rem;
                font-weight: 560;
                letter-spacing: 0.025em;
                text-decoration: none;
                transition: color 160ms ease;
        }

        :global(header[data-overlay="true"] nav a:not(.logo)),
        :global(header.is-scrolled nav a:not(.logo)),
        :global(header.menu-open nav a:not(.logo)) {
                color: rgba(244, 239, 220, 0.74);
        }

        :global(header[data-site-header] nav a:not(.logo)::after) {
                content: "";
                position: absolute;
                left: 0;
                right: 100%;
                bottom: 3px;
                height: 1px;
                background: #d5af38;
                transition: right 180ms ease;
        }

        :global(header[data-site-header] nav a:not(.logo):hover),
        :global(header[data-site-header] nav a:not(.logo):focus-visible),
        :global(header[data-site-header] nav a.active) {
                color: #c59d26;
                outline: none;
        }

        :global(header[data-overlay="true"] nav a:not(.logo):hover),
        :global(header[data-overlay="true"] nav a:not(.logo):focus-visible),
        :global(header[data-overlay="true"] nav a.active),
        :global(header.is-scrolled nav a:not(.logo):hover),
        :global(header.is-scrolled nav a:not(.logo):focus-visible),
        :global(header.is-scrolled nav a.active) {
                color: #e2bd4d;
        }

        :global(header[data-site-header] nav a:not(.logo):hover::after),
        :global(header[data-site-header] nav a:not(.logo):focus-visible::after),
        :global(header[data-site-header] nav a.active::after) {
                right: 0;
        }

        .menu-toggle {
                display: none;
                min-width: 78px;
                min-height: 44px;
                padding: 0.5rem 0.65rem;
                align-items: center;
                justify-content: space-between;
                gap: 0.7rem;
                border: 1px solid rgba(224, 197, 93, 0.28);
                border-radius: 2px;
                color: #e6dba9;
                background: rgba(7, 43, 33, 0.48);
                font: inherit;
                cursor: pointer;
        }

        .menu-toggle-label {
                font-family: "Archivo Variable", "Atkinson", sans-serif;
                font-size: 0.65rem;
                font-weight: 640;
                letter-spacing: 0.08em;
                text-transform: uppercase;
        }

        .menu-toggle-icon {
                position: relative;
                width: 17px;
                height: 11px;
        }

        .menu-toggle-icon i {
                position: absolute;
                left: 0;
                width: 100%;
                height: 1px;
                background: currentColor;
                transition: transform 180ms ease, top 180ms ease;
        }

        .menu-toggle-icon i:first-child { top: 2px; }
        .menu-toggle-icon i:last-child { top: 8px; }
        .menu-open .menu-toggle-icon i:first-child { top: 5px; transform: rotate(45deg); }
        .menu-open .menu-toggle-icon i:last-child { top: 5px; transform: rotate(-45deg); }

        @media (max-width: 760px) {
                header,
                header[data-overlay="true"],
                header.is-scrolled,
                header[data-overlay="true"].is-scrolled,
                header.menu-open {
                        min-height: 68px;
                        padding: 0 0.8rem;
                }

                nav {
                        gap: 0.75rem;
                }

                .logo {
                        width: min(208px, 56vw);
                        height: 48px;
                }

                .menu-toggle {
                        display: inline-flex;
                }
        }

        @media (prefers-reduced-motion: reduce) {
                header,
                .menu-toggle-icon i,
                :global(header[data-site-header] nav a:not(.logo)::after) {
                        transition: none;
                }
        }
</style>

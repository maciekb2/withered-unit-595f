---
import HeaderLink from './HeaderLink.astro';
---

<div class="menu" id="site-menu">
    <HeaderLink href="/">Strona główna</HeaderLink>
    <HeaderLink href="/blog">Blog</HeaderLink>
    <HeaderLink href="/tematy">Tematy</HeaderLink>
    <HeaderLink href="/about">O mnie</HeaderLink>
    <HeaderLink href="/contact">Kontakt</HeaderLink>
</div>

<style>
    .menu {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: clamp(1rem, 2.15vw, 1.8rem);
        min-width: 0;
    }

    @media (max-width: 760px) {
        .menu {
            position: absolute;
            top: calc(100% - 1px);
            left: 0;
            right: 0;
            padding: 0.75rem;
            display: grid;
            align-items: stretch;
            justify-content: stretch;
            gap: 0;
            border: 1px solid rgba(220, 188, 73, 0.2);
            background: rgba(4, 28, 22, 0.98);
            box-shadow: 0 24px 44px rgba(0, 10, 7, 0.38);
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
            transform: translateY(-8px);
            transition: opacity 180ms ease, transform 180ms ease, visibility 180ms ease;
        }

        :global([data-site-header].menu-open) .menu {
            opacity: 1;
            visibility: visible;
            pointer-events: auto;
            transform: translateY(0);
        }

        .menu :global(a) {
            width: 100%;
            min-height: 48px;
            padding: 0.65rem 0.35rem;
            border-bottom: 1px solid rgba(224, 208, 145, 0.1);
        }

        .menu :global(a:last-child) {
            border-bottom: 0;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .menu { transition: none; }
    }
</style>

---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { GA4_MEASUREMENT_ID, GOOGLE_SITE_VERIFICATION, SITE_KEYWORDS } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: string;
	type?: 'website' | 'article';
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = '/pseudointelekt_logo_tekstura.svg', type = 'website' } = Astro.props;
const imageURL = new URL(image, Astro.site);
const hasGoogleVerification = Boolean(GOOGLE_SITE_VERIFICATION);
const websiteJsonLd = type === 'website'
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Pseudointelekt',
      url: new URL('/', Astro.site).toString(),
      inLanguage: 'pl-PL',
      description,
    }
  : undefined;
---

<!-- Global Metadata --> 
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon_P1.svg" />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" type="application/rss+xml" title="Pseudointelekt — RSS" href="/rss.xml" />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="Pseudointelekt" />
<meta name="keywords" content={SITE_KEYWORDS} />
{hasGoogleVerification && <meta name="google-site-verification" content={GOOGLE_SITE_VERIFICATION} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:locale" content="pl_PL" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

{websiteJsonLd && <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />}

<script define:vars={{ ga4Id: GA4_MEASUREMENT_ID }}>
(() => {
  const consentKey = 'pseudointelekt_cookie_consent_v2';
  const consentVersion = 2;
  const hasGa4 = typeof ga4Id === 'string' && /^G-[A-Z0-9]+$/i.test(ga4Id);
  let analyticsGranted = false;

  window.dataLayer = window.dataLayer || [];
  window.gtag = window.gtag || function gtag(){ window.dataLayer.push(arguments); };
  window.pseudointelektTrack = function pseudointelektTrack(eventName, params = {}) {
    if (!analyticsGranted || !hasGa4 || typeof window.gtag !== 'function') return;
    if (!/^[a-z][a-z0-9_]{1,39}$/.test(eventName)) return;
    window.gtag('event', eventName, {
      site_section: document.body?.dataset?.pageSection || 'unknown',
      ...params,
    });
  };
  window.gtag('consent', 'default', {
    analytics_storage: 'denied',
    ad_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied',
    functionality_storage: 'granted',
    security_storage: 'granted',
    wait_for_update: 500,
  });

  function readConsent() {
    try {
      const value = JSON.parse(localStorage.getItem(consentKey) || 'null');
      return value && value.version === consentVersion ? value : null;
    } catch {
      return null;
    }
  }

  function saveConsent(analytics) {
    const wasGranted = analyticsGranted;
    const value = {
      version: consentVersion,
      analytics: Boolean(analytics),
      updatedAt: new Date().toISOString(),
    };
    localStorage.setItem(consentKey, JSON.stringify(value));
    applyConsent(value);
    if (!wasGranted && value.analytics) {
      window.pseudointelektTrack('analytics_consent_granted', {
        consent_version: consentVersion,
      });
    }
  }

  function applyConsent(consent) {
    const granted = Boolean(consent && consent.analytics);
    analyticsGranted = granted;
    window.gtag('consent', 'update', {
      analytics_storage: granted ? 'granted' : 'denied',
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
    });
    if (granted) loadGa4();
  }

  function loadGa4() {
    if (!hasGa4 || document.querySelector('script[data-ga4-loader]')) return;
    const script = document.createElement('script');
    script.async = true;
    script.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(ga4Id)}`;
    script.dataset.ga4Loader = 'true';
    document.head.appendChild(script);
    window.gtag('js', new Date());
    window.gtag('config', ga4Id, { anonymize_ip: true });
  }

  function createButton(label, variant, onClick) {
    const button = document.createElement('button');
    button.type = 'button';
    button.className = `cookie-consent__button cookie-consent__button--${variant}`;
    button.textContent = label;
    button.addEventListener('click', onClick);
    return button;
  }

  function hideBanner() {
    document.querySelector('[data-cookie-consent-banner]')?.remove();
  }

  function showBanner() {
    if (document.querySelector('[data-cookie-consent-banner]')) return;

    const banner = document.createElement('section');
    banner.className = 'cookie-consent';
    banner.dataset.cookieConsentBanner = 'true';
    banner.setAttribute('role', 'dialog');
    banner.setAttribute('aria-modal', 'true');
    banner.setAttribute('aria-labelledby', 'cookie-consent-title');
    banner.innerHTML = `
      <div class="cookie-consent__backdrop" aria-hidden="true"></div>
      <div class="cookie-consent__panel">
        <p class="cookie-consent__eyebrow">Twoja prywatność</p>
        <h2 id="cookie-consent-title">Decyzja należy do Ciebie.</h2>
        <p>Używamy niezbędnych mechanizmów dla działania strony. Analitykę Google uruchomimy tylko za Twoją zgodą.</p>
        <a href="/privacy">Zobacz politykę prywatności i cookies</a>
        <div class="cookie-consent__actions"></div>
      </div>
    `;

    const actions = banner.querySelector('.cookie-consent__actions');
    actions.append(
      createButton('Odrzucam analitykę', 'secondary', () => {
        saveConsent(false);
        hideBanner();
      }),
      createButton('Akceptuję analitykę', 'primary', () => {
        saveConsent(true);
        hideBanner();
      }),
    );
    document.body.appendChild(banner);
    banner.querySelector('button')?.focus();
  }

  function addStyles() {
    if (document.querySelector('style[data-cookie-consent-style]')) return;
    const style = document.createElement('style');
    style.dataset.cookieConsentStyle = 'true';
    style.textContent = `
      .cookie-consent {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: grid;
        place-items: center;
        padding: 1rem;
      }
      .cookie-consent__backdrop {
        position: absolute;
        inset: 0;
        background: rgba(1, 17, 12, 0.6);
        backdrop-filter: blur(8px);
      }
      .cookie-consent__panel {
        position: relative;
        width: min(470px, 100%);
        padding: 1.35rem;
        border: 1px solid rgba(224, 202, 118, 0.3);
        border-radius: 14px;
        background: linear-gradient(145deg, rgba(8, 48, 37, 0.94), rgba(3, 29, 22, 0.92));
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.38);
        color: #f1eee5;
      }
      .cookie-consent__eyebrow {
        margin: 0 0 0.45rem;
        color: #d9b53e;
        font-family: "Archivo Variable", "Atkinson", sans-serif;
        font-size: 0.66rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .cookie-consent h2 {
        margin: 0;
        color: #f1eee5;
        font-family: "Archivo Variable", "Atkinson", sans-serif;
        font-size: clamp(1.45rem, 4vw, 2rem);
        line-height: 1.05;
      }
      .cookie-consent__panel > p:not(.cookie-consent__eyebrow) {
        margin: 0.75rem 0 0;
        color: rgba(241, 238, 229, 0.75);
        font-size: 0.92rem;
        line-height: 1.5;
      }
      .cookie-consent__panel > a {
        display: inline-flex;
        margin-top: 0.85rem;
        color: #d9b53e;
        font-size: 0.82rem;
        font-weight: 700;
      }
      .cookie-consent__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: 1.15rem;
      }
      .cookie-consent__button {
        min-height: 2.55rem;
        flex: 1 1 170px;
        border: 1px solid rgba(224, 202, 118, 0.38);
        border-radius: 8px;
        padding: 0.6rem 0.85rem;
        font-family: "Archivo Variable", "Atkinson", sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        cursor: pointer;
        transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
      }
      .cookie-consent__button:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 18px rgba(20, 26, 33, 0.14);
      }
      .cookie-consent__button--primary {
        border-color: #d9b53e;
        background: #d9b53e;
        color: #072b21;
      }
      .cookie-consent__button--secondary {
        background: rgba(3, 29, 22, 0.54);
        color: #f1eee5;
      }
      @media (max-width: 680px) {
        .cookie-consent__button {
          flex: 1 1 100%;
        }
      }
    `;
    document.head.appendChild(style);
  }

  document.addEventListener('DOMContentLoaded', () => {
    addStyles();
    document.addEventListener('click', (event) => {
      const link = event.target instanceof Element ? event.target.closest('a[href]') : null;
      if (!(link instanceof HTMLAnchorElement)) return;
      const url = new URL(link.href, window.location.href);
      if (url.hostname === window.location.hostname) return;
      window.pseudointelektTrack('outbound_click', {
        link_domain: url.hostname.replace(/^www\./, ''),
      });
    }, { capture: true });

    document.querySelectorAll('[data-cookie-consent-open]').forEach((button) => button.addEventListener('click', showBanner));
    const consent = readConsent();
    if (consent) applyConsent(consent);
    else showBanner();
  });
})();
</script>

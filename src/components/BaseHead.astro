---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { GA4_MEASUREMENT_ID, GOOGLE_SITE_VERIFICATION, SITE_KEYWORDS } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: string;
	type?: 'website' | 'article';
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = '/pseudointelekt_logo_tekstura.svg', type = 'website' } = Astro.props;
const imageURL = new URL(image, Astro.site);
const hasGoogleVerification = Boolean(GOOGLE_SITE_VERIFICATION);
---

<!-- Global Metadata --> 
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon_P1.svg" />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content="index, follow" />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="keywords" content={SITE_KEYWORDS} />
{hasGoogleVerification && <meta name="google-site-verification" content={GOOGLE_SITE_VERIFICATION} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

<script define:vars={{ ga4Id: GA4_MEASUREMENT_ID }}>
(() => {
  const consentKey = 'pseudointelekt_cookie_consent_v2';
  const consentVersion = 2;
  const hasGa4 = typeof ga4Id === 'string' && /^G-[A-Z0-9]+$/i.test(ga4Id);
  let analyticsGranted = false;

  window.dataLayer = window.dataLayer || [];
  window.gtag = window.gtag || function gtag(){ window.dataLayer.push(arguments); };
  window.pseudointelektTrack = function pseudointelektTrack(eventName, params = {}) {
    if (!analyticsGranted || !hasGa4 || typeof window.gtag !== 'function') return;
    if (!/^[a-z][a-z0-9_]{1,39}$/.test(eventName)) return;
    window.gtag('event', eventName, {
      site_section: document.body?.dataset?.pageSection || 'unknown',
      ...params,
    });
  };
  window.gtag('consent', 'default', {
    analytics_storage: 'denied',
    ad_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied',
    functionality_storage: 'granted',
    security_storage: 'granted',
  });

  function readConsent() {
    try {
      const value = JSON.parse(localStorage.getItem(consentKey) || 'null');
      return value && value.version === consentVersion ? value : null;
    } catch {
      return null;
    }
  }

  function saveConsent(analytics) {
    const wasGranted = analyticsGranted;
    const value = {
      version: consentVersion,
      analytics: Boolean(analytics),
      updatedAt: new Date().toISOString(),
    };
    localStorage.setItem(consentKey, JSON.stringify(value));
    applyConsent(value);
    if (!wasGranted && value.analytics) {
      window.pseudointelektTrack('analytics_consent_granted', {
        consent_version: consentVersion,
      });
    }
  }

  function applyConsent(consent) {
    const granted = Boolean(consent && consent.analytics);
    analyticsGranted = granted;
    window.gtag('consent', 'update', {
      analytics_storage: granted ? 'granted' : 'denied',
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
    });
    if (granted) loadGa4();
  }

  function loadGa4() {
    if (!hasGa4 || document.querySelector('script[data-ga4-loader]')) return;
    const script = document.createElement('script');
    script.async = true;
    script.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(ga4Id)}`;
    script.dataset.ga4Loader = 'true';
    document.head.appendChild(script);
    window.gtag('js', new Date());
    window.gtag('config', ga4Id, { anonymize_ip: true });
  }

  function createButton(label, variant, onClick) {
    const button = document.createElement('button');
    button.type = 'button';
    button.className = `cookie-consent__button cookie-consent__button--${variant}`;
    button.textContent = label;
    button.addEventListener('click', onClick);
    return button;
  }

  function hideBanner() {
    document.querySelector('[data-cookie-consent-banner]')?.remove();
  }

  function showManageButton() {
    if (document.querySelector('[data-cookie-consent-manage]')) return;
    const button = document.createElement('button');
    button.type = 'button';
    button.className = 'cookie-consent-manage';
    button.dataset.cookieConsentManage = 'true';
    button.textContent = 'Ustawienia cookies';
    button.addEventListener('click', showBanner);
    document.body.appendChild(button);
  }

  function showBanner() {
    if (document.querySelector('[data-cookie-consent-banner]')) return;

    const banner = document.createElement('section');
    banner.className = 'cookie-consent';
    banner.dataset.cookieConsentBanner = 'true';
    banner.setAttribute('aria-label', 'Ustawienia prywatności');
    banner.innerHTML = `
      <div class="cookie-consent__copy">
        <strong>Cookies i prywatność</strong>
        <p>Niezbędne technologie pomagają stronie działać i chronić formularze. Google Analytics włączymy wyłącznie, jeśli wyrazisz zgodę.</p>
        <a href="/privacy">Zobacz politykę prywatności i cookies</a>
      </div>
      <div class="cookie-consent__actions"></div>
    `;

    const actions = banner.querySelector('.cookie-consent__actions');
    actions.append(
      createButton('Odrzuć analitykę', 'secondary', () => {
        saveConsent(false);
        hideBanner();
        showManageButton();
      }),
      createButton('Akceptuję analitykę', 'primary', () => {
        saveConsent(true);
        hideBanner();
        showManageButton();
      }),
    );
    document.body.appendChild(banner);
  }

  function addStyles() {
    if (document.querySelector('style[data-cookie-consent-style]')) return;
    const style = document.createElement('style');
    style.dataset.cookieConsentStyle = 'true';
    style.textContent = `
      .cookie-consent {
        position: fixed;
        left: 50%;
        bottom: 1rem;
        z-index: 1000;
        width: min(720px, calc(100vw - 2rem));
        transform: translateX(-50%);
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 1rem;
        align-items: center;
        padding: 1rem;
        border: 1px solid rgba(28, 61, 90, 0.18);
        border-radius: 8px;
        background: rgba(248, 246, 241, 0.98);
        box-shadow: 0 18px 48px rgba(20, 26, 33, 0.18);
        color: var(--charcoal, #2b2b2b);
      }
      .cookie-consent__copy strong {
        display: block;
        margin-bottom: 0.3rem;
        color: var(--diplomatic-blue, #1c3d5a);
      }
      .cookie-consent__copy p {
        margin: 0 0 0.35rem;
        line-height: 1.45;
      }
      .cookie-consent__copy a {
        color: var(--accent-dark, #8a6518);
      }
      .cookie-consent__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        justify-content: flex-end;
      }
      .cookie-consent__button {
        min-height: 2.45rem;
        border: 1px solid rgba(28, 61, 90, 0.26);
        border-radius: 999px;
        padding: 0.55rem 0.85rem;
        font: inherit;
        cursor: pointer;
        transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
      }
      .cookie-consent__button:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 18px rgba(20, 26, 33, 0.14);
      }
      .cookie-consent__button--primary {
        border-color: var(--diplomatic-blue, #1c3d5a);
        background: var(--diplomatic-blue, #1c3d5a);
        color: var(--ivory, #fffaf0);
      }
      .cookie-consent__button--secondary {
        background: transparent;
        color: var(--diplomatic-blue, #1c3d5a);
      }
      .cookie-consent-manage {
        position: fixed;
        left: 1rem;
        bottom: 1rem;
        z-index: 999;
        min-height: 2.2rem;
        border: 1px solid rgba(28, 61, 90, 0.22);
        border-radius: 999px;
        padding: 0.45rem 0.72rem;
        background: rgba(248, 246, 241, 0.9);
        color: var(--diplomatic-blue, #1c3d5a);
        font: inherit;
        font-size: 0.86rem;
        cursor: pointer;
        box-shadow: 0 8px 20px rgba(20, 26, 33, 0.12);
      }
      .cookie-consent-manage:hover {
        background: rgba(248, 246, 241, 0.98);
      }
      @media (max-width: 680px) {
        .cookie-consent {
          grid-template-columns: 1fr;
        }
        .cookie-consent__actions {
          justify-content: stretch;
        }
        .cookie-consent__button {
          flex: 1 1 100%;
        }
      }
    `;
    document.head.appendChild(style);
  }

  document.addEventListener('DOMContentLoaded', () => {
    addStyles();
    document.addEventListener('click', (event) => {
      const link = event.target instanceof Element ? event.target.closest('a[href]') : null;
      if (!(link instanceof HTMLAnchorElement)) return;
      const url = new URL(link.href, window.location.href);
      if (url.hostname === window.location.hostname) return;
      window.pseudointelektTrack('outbound_click', {
        link_domain: url.hostname.replace(/^www\./, ''),
      });
    }, { capture: true });

    const consent = readConsent();
    if (consent) {
      applyConsent(consent);
      showManageButton();
    } else {
      showBanner();
    }
  });
})();
</script>

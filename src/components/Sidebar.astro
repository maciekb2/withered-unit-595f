---
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

const posts = await getCollection('blog');

const mostViewed = [...posts]
  .sort((a, b) => (b.data.views ?? 0) - (a.data.views ?? 0))
  .slice(0, 5);
const mostLiked = [...posts]
  .sort((a, b) => (b.data.likes ?? 0) - (a.data.likes ?? 0))
  .slice(0, 3);
const newest = [...posts]
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<aside class="sidebar">
  <p class="sidebar-kicker">Na skróty</p>
  <section>
    <h3>Najczęściej czytane</h3>
    <ul id="most-viewed-list">
      {mostViewed.map((post) => (
        <li data-slug={post.id} data-views={post.data.views}>
          <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          <span class="count">{post.data.views}</span>
        </li>
      ))}
    </ul>
  </section>
  <details>
    <summary>Najwięcej polubień</summary>
    <ul id="most-liked-list">
      {mostLiked.map((post) => (
        <li data-slug={post.id} data-likes={post.data.likes}>
          <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          <span class="count">{post.data.likes}</span>
        </li>
      ))}
    </ul>
  </details>
  <details>
    <summary>Najnowsze artykuły</summary>
    <ul>
      {newest.map((post) => (
        <li>
          <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          <FormattedDate date={post.data.pubDate} />
        </li>
      ))}
    </ul>
  </details>
</aside>
<script type="module">
  const list = document.getElementById('most-viewed-list');
  if (list) {
    const items = Array.from(list.querySelectorAll('li'));
    fetch('/api/views')
      .then((r) => (r.ok ? r.json() : {}))
      .then((data) => {
        items.forEach((li) => {
          const slug = li.dataset.slug;
          if (slug && data[slug] != null) {
            li.dataset.views = data[slug];
            const span = li.querySelector('.count');
            if (span) span.textContent = data[slug];
          }
        });
        items.sort(
          (a, b) => parseInt(b.dataset.views || '0') - parseInt(a.dataset.views || '0')
        );
        items.forEach((li) => list.appendChild(li));
      });
  }
  const likeList = document.getElementById('most-liked-list');
  if (likeList) {
    const items = Array.from(likeList.querySelectorAll('li'));
    fetch('/api/likes')
      .then((r) => (r.ok ? r.json() : {}))
      .then((data) => {
        items.forEach((li) => {
          const slug = li.dataset.slug;
          if (slug && data[slug] != null) {
            li.dataset.likes = data[slug];
            const span = li.querySelector('.count');
            if (span) span.textContent = data[slug];
          }
        });
        items.sort(
          (a, b) => parseInt(b.dataset.likes || '0') - parseInt(a.dataset.likes || '0')
        );
        items.forEach((li) => likeList.appendChild(li));
      });
  }
</script>

<style>
  .sidebar {
    padding: 1.1rem;
    color: var(--ivory);
    background: rgba(7, 43, 33, 0.78);
    border: 1px solid rgba(224, 202, 118, 0.2);
    border-radius: 12px;
    width: auto;
    box-shadow: 0 14px 34px rgba(2, 20, 15, 0.22);
  }
  h3 {
    margin: 0 0 0.85rem;
    color: var(--gold-accent);
    font-family: 'Archivo Variable', sans-serif;
  }
  ul {
    list-style: none;
    padding-left: 0;
  }
  li {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.55rem;
    margin-bottom: 0.72rem;
    font-size: 0.86rem;
    line-height: 1.35;
  }
  a {
    color: rgba(241, 238, 229, 0.82);
    text-decoration: none;
  }
  .count {
    color: var(--gold-accent);
  }
  .sidebar-kicker {
    margin: 0 0 0.4rem;
    color: var(--gold-accent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  details {
    padding-top: 0.85rem;
    border-top: 1px solid rgba(224, 202, 118, 0.16);
  }
  summary {
    color: rgba(241, 238, 229, 0.84);
    cursor: pointer;
    font-size: 0.88rem;
    font-weight: 700;
  }
  details ul { margin: 0.85rem 0 0; }
  time { color: rgba(241, 238, 229, 0.56); font-size: 0.78rem; }
</style>

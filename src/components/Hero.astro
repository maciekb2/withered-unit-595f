---
type HeroHeadline = {
    title: string;
    href: string;
    dateLabel?: string;
};

interface Props {
    liveHeadlines?: HeroHeadline[];
    articleCount?: number;
    lastPublishedLabel?: string;
}

const {
    liveHeadlines = [],
    articleCount,
    lastPublishedLabel,
} = Astro.props as Props;

const tickerItems = liveHeadlines.length > 0
    ? [...liveHeadlines, ...liveHeadlines]
    : [];
---

<section class="hero" aria-labelledby="hero-title">
    <div class="hero-background" aria-hidden="true">
        <div class="geo-grid"></div>
        <div class="aurora aurora-a"></div>
        <div class="aurora aurora-b"></div>
    </div>
    <div class="hero-shell">
        <div class="hero-copy">
            <p class="kicker">GEOPOLITYKA · SATYRA · KONTEKST</p>
            <h1 id="hero-title">
                <span class="hero-title-text" data-hero-text aria-live="polite">
                    Analiza globalnej geopolityki bez zadęcia
                </span>
            </h1>
            <p class="subtitle">
                Pseudointelekt filtruje chaos informacyjny przez ironię i konkret. Bez korpo-jargonu,
                za to z dystansem do wielkich narracji i małych spinów.
            </p>
            <div class="hero-actions">
                <a class="cta cta-primary" href="/blog">Czytaj najnowsze wpisy</a>
                <a class="cta cta-secondary" href="/about">Poznaj autora</a>
            </div>
            <ul class="hero-tags">
                <li>Geopolityka bez korpomowy</li>
                <li>Ironia zamiast patosu</li>
                <li>Komentarz z lokalnej kanapy</li>
            </ul>
            <div class="hero-metrics" aria-label="Szybki podgląd serwisu">
                {typeof articleCount === 'number' && (
                    <div class="metric">
                        <span class="metric-label">Artykułów</span>
                        <strong>{articleCount}</strong>
                    </div>
                )}
                {lastPublishedLabel && (
                    <div class="metric">
                        <span class="metric-label">Ostatni sygnał</span>
                        <strong>{lastPublishedLabel}</strong>
                    </div>
                )}
            </div>
        </div>
        <div class="hero-visual-wrap" aria-hidden="true">
            <div class="hero-visual">
                <div class="orbit orbit-outer"></div>
                <div class="orbit orbit-middle"></div>
                <div class="orbit orbit-inner"></div>
                <div class="scan"></div>
                <div class="core"></div>
                <span class="node node-a"></span>
                <span class="node node-b"></span>
                <span class="node node-c"></span>
                <span class="node node-d"></span>
            </div>
            <div class="signal-panel signal-one">
                <span class="signal-label">Strefa wpływów</span>
                <strong>Narracje przemieszczają front</strong>
            </div>
            <div class="signal-panel signal-two">
                <span class="signal-label">Sygnał dnia</span>
                <strong>Dyplomacja z domieszką absurdu</strong>
            </div>
        </div>
    </div>
    {liveHeadlines.length > 0 && (
        <div class="intel-feed" aria-label="Najnowsze sygnały">
            <p class="intel-title">Live feed</p>
            <div class="intel-track">
                <div class="intel-row">
                    {tickerItems.map((item) => (
                        <a class="intel-item" href={item.href}>
                            {item.dateLabel && <span class="intel-date">{item.dateLabel}</span>}
                            <span>{item.title}</span>
                        </a>
                    ))}
                </div>
            </div>
        </div>
    )}
</section>
<script>
    const hero = document.querySelector('.hero');

    if (hero instanceof HTMLElement) {
        const titleText = hero.querySelector('[data-hero-text]');
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
        const messages = [
            "Analiza globalnej geopolityki bez zadęcia",
            "Konflikty, sojusze i absurd dnia codziennego",
            "Światowa polityka pod lupą i z ironią",
            "Think-tank spotyka mema w jednej osi czasu",
        ];

        let messageIndex = 0;
        let rotationTimer = null;
        let frameId = 0;
        let pointerX = window.innerWidth / 2;
        let pointerY = window.innerHeight / 2;
        let viewportObserver = null;

        const stopRotation = () => {
            if (rotationTimer !== null) {
                window.clearInterval(rotationTimer);
                rotationTimer = null;
            }
        };

        const swapMessage = () => {
            if (!(titleText instanceof HTMLElement)) return;
            titleText.classList.add('is-swapping');
            window.setTimeout(() => {
                messageIndex = (messageIndex + 1) % messages.length;
                titleText.textContent = messages[messageIndex];
                titleText.classList.remove('is-swapping');
            }, 180);
        };

        const startRotation = () => {
            if (
                rotationTimer !== null ||
                prefersReducedMotion.matches ||
                !(titleText instanceof HTMLElement)
            ) {
                return;
            }
            rotationTimer = window.setInterval(swapMessage, 4600);
        };

        const queueMotionUpdate = () => {
            if (frameId !== 0) return;
            frameId = window.requestAnimationFrame(() => {
                frameId = 0;
                const rect = hero.getBoundingClientRect();
                if (!rect.width || !rect.height) return;

                const clampedX = Math.min(Math.max(pointerX, rect.left), rect.right);
                const clampedY = Math.min(Math.max(pointerY, rect.top), rect.bottom);
                const relX = clampedX - rect.left;
                const relY = clampedY - rect.top;
                const normX = relX / rect.width - 0.5;
                const normY = relY / rect.height - 0.5;

                hero.style.setProperty('--pointer-x', `${relX.toFixed(1)}px`);
                hero.style.setProperty('--pointer-y', `${relY.toFixed(1)}px`);

                if (prefersReducedMotion.matches) {
                    hero.style.setProperty('--tilt-x', '0');
                    hero.style.setProperty('--tilt-y', '0');
                    return;
                }

                hero.style.setProperty('--tilt-x', normX.toFixed(4));
                hero.style.setProperty('--tilt-y', normY.toFixed(4));
            });
        };

        const centerPointer = () => {
            const rect = hero.getBoundingClientRect();
            pointerX = rect.left + rect.width / 2;
            pointerY = rect.top + rect.height / 2;
            queueMotionUpdate();
        };

        const onPointerMove = (event) => {
            if (prefersReducedMotion.matches) return;
            pointerX = event.clientX;
            pointerY = event.clientY;
            queueMotionUpdate();
        };

        const onMotionPreferenceChange = (event) => {
            if (event.matches) {
                stopRotation();
                hero.style.setProperty('--tilt-x', '0');
                hero.style.setProperty('--tilt-y', '0');
            } else {
                startRotation();
            }
            centerPointer();
        };

        const setAnimationsPlayState = (isRunning) => {
            hero.style.setProperty('--hero-animation-play-state', isRunning ? 'running' : 'paused');
        };

        if (typeof prefersReducedMotion.addEventListener === 'function') {
            prefersReducedMotion.addEventListener('change', onMotionPreferenceChange);
        } else if (typeof prefersReducedMotion.addListener === 'function') {
            prefersReducedMotion.addListener(onMotionPreferenceChange);
        }

        startRotation();
        centerPointer();
        setAnimationsPlayState(true);

        if ('IntersectionObserver' in window) {
            viewportObserver = new IntersectionObserver(
                ([entry]) => {
                    const isVisible = Boolean(entry && entry.isIntersecting);
                    setAnimationsPlayState(isVisible);
                },
                { threshold: 0.08 },
            );
            viewportObserver.observe(hero);
        }

        hero.addEventListener('pointermove', onPointerMove, { passive: true });
        hero.addEventListener('pointerleave', centerPointer, { passive: true });
        window.addEventListener('scroll', queueMotionUpdate, { passive: true });
        window.addEventListener('resize', centerPointer, { passive: true });
        window.addEventListener('pagehide', () => {
            stopRotation();
            if (viewportObserver) viewportObserver.disconnect();
            if (frameId !== 0) window.cancelAnimationFrame(frameId);
        });
    }
</script>
<style>
    .hero {
        --pointer-x: 50%;
        --pointer-y: 50%;
        --tilt-x: 0;
        --tilt-y: 0;
        --hero-animation-play-state: running;
        position: relative;
        width: 100%;
        margin: 0;
        overflow: clip;
        color: var(--ivory);
        background:
            radial-gradient(
                circle at var(--pointer-x) var(--pointer-y),
                rgba(229, 216, 195, 0.2),
                transparent 55%
            ),
            linear-gradient(140deg, #01301d 0%, #014421 44%, #1c3d5a 100%);
        border-bottom: 1px solid rgba(229, 216, 195, 0.22);
    }

    .hero::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: radial-gradient(circle at 20% 10%, rgba(203, 161, 53, 0.16), transparent 40%);
        mix-blend-mode: screen;
    }

    .hero-background {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
    }

    .geo-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(248, 246, 241, 0.08) 1px, transparent 1px),
            linear-gradient(90deg, rgba(248, 246, 241, 0.08) 1px, transparent 1px);
        background-size: 44px 44px;
        mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.9), transparent 88%);
        animation: gridShift 28s linear infinite;
        animation-play-state: var(--hero-animation-play-state);
    }

    .aurora {
        position: absolute;
        width: min(58vw, 680px);
        height: min(58vw, 680px);
        border-radius: 50%;
        filter: blur(36px);
        opacity: 0.55;
        will-change: transform;
        animation: auroraDrift 16s ease-in-out infinite alternate;
        animation-play-state: var(--hero-animation-play-state);
    }

    .aurora-a {
        top: -24%;
        right: -10%;
        background: radial-gradient(circle, rgba(203, 161, 53, 0.32), transparent 62%);
    }

    .aurora-b {
        bottom: -38%;
        left: -16%;
        background: radial-gradient(circle, rgba(28, 61, 90, 0.5), transparent 66%);
        animation-delay: -8s;
    }

    .hero-shell {
        position: relative;
        z-index: 1;
        width: min(1120px, calc(100% - 2rem));
        margin: 0 auto;
        min-height: clamp(560px, calc(100svh - 5rem), 820px);
        padding: clamp(3rem, 6vw, 5rem) 0 clamp(4rem, 8vw, 6rem);
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
        align-items: center;
        gap: clamp(1.5rem, 4vw, 4rem);
    }

    .hero-copy {
        max-width: 640px;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        transform: translate3d(
            calc(var(--tilt-x) * -16px),
            calc(var(--tilt-y) * -10px),
            0
        );
        transition: transform 200ms ease-out;
    }

    .hero-copy > * {
        opacity: 0;
        transform: translateY(14px);
        animation: riseIn 680ms cubic-bezier(0.2, 0.75, 0.3, 1) forwards;
        animation-play-state: var(--hero-animation-play-state);
    }

    .hero-copy > :nth-child(1) { animation-delay: 60ms; }
    .hero-copy > :nth-child(2) { animation-delay: 120ms; }
    .hero-copy > :nth-child(3) { animation-delay: 190ms; }
    .hero-copy > :nth-child(4) { animation-delay: 250ms; }
    .hero-copy > :nth-child(5) { animation-delay: 320ms; }
    .hero-copy > :nth-child(6) { animation-delay: 380ms; }

    .kicker {
        margin: 0;
        display: inline-flex;
        align-items: center;
        width: fit-content;
        gap: 0.5rem;
        padding: 0.35rem 0.85rem;
        border: 1px solid rgba(248, 246, 241, 0.26);
        border-radius: 999px;
        font-size: 0.78rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        background: rgba(248, 246, 241, 0.08);
    }

    h1 {
        margin: 0;
        max-width: 22ch;
        font-size: clamp(2.1rem, 5.1vw, 4.25rem);
        line-height: 1.05;
        color: var(--gold-accent);
        text-wrap: balance;
    }

    .hero-title-text {
        display: inline-block;
        transition: opacity 280ms ease, transform 280ms ease;
    }

    .hero-title-text.is-swapping {
        opacity: 0;
        transform: translateY(-8px);
    }

    .subtitle {
        margin: 0;
        max-width: 58ch;
        color: rgba(248, 246, 241, 0.92);
        font-size: clamp(1.02rem, 1.35vw, 1.24rem);
        text-wrap: pretty;
    }

    .hero-actions {
        display: flex;
        gap: 0.9rem;
        flex-wrap: wrap;
        margin-top: 0.7rem;
    }

    .cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0.72rem 1.45rem;
        border-radius: 0.55rem;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.94rem;
        transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease, color 160ms ease;
    }

    .cta-primary {
        color: var(--charcoal);
        background: var(--gold-accent);
        box-shadow: 0 10px 24px rgba(203, 161, 53, 0.25);
    }

    .cta-secondary {
        color: var(--ivory);
        border: 1px solid rgba(248, 246, 241, 0.4);
        background: rgba(248, 246, 241, 0.09);
    }

    .cta:hover {
        transform: translateY(-2px);
    }

    .cta-primary:hover {
        background: #ddbb65;
        box-shadow: 0 12px 30px rgba(221, 187, 101, 0.34);
    }

    .cta-secondary:hover {
        background: rgba(248, 246, 241, 0.2);
    }

    .hero-tags {
        margin: 0.35rem 0 0 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        list-style: none;
    }

    .hero-tags li {
        padding: 0.34rem 0.68rem;
        border-radius: 999px;
        background: rgba(1, 68, 33, 0.45);
        border: 1px solid rgba(248, 246, 241, 0.18);
        font-size: 0.82rem;
        letter-spacing: 0.01em;
    }

    .hero-metrics {
        display: flex;
        gap: 0.62rem;
        flex-wrap: wrap;
        margin-top: 0.15rem;
    }

    .metric {
        display: grid;
        gap: 0.12rem;
        min-width: 140px;
        padding: 0.48rem 0.62rem;
        border: 1px solid rgba(248, 246, 241, 0.22);
        border-radius: 0.58rem;
        background: rgba(1, 68, 33, 0.35);
    }

    .metric-label {
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.11em;
        opacity: 0.85;
    }

    .metric strong {
        font-size: 0.9rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .hero-visual-wrap {
        position: relative;
        justify-self: end;
        width: min(42vw, 460px);
        aspect-ratio: 1 / 1;
        transform: translate3d(
            calc(var(--tilt-x) * 18px),
            calc(var(--tilt-y) * 12px),
            0
        );
        transition: transform 220ms ease-out;
    }

    .hero-visual {
        position: absolute;
        inset: 7%;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(248, 246, 241, 0.12) 0%, rgba(1, 68, 33, 0.6) 62%, rgba(1, 68, 33, 0.12) 100%);
        border: 1px solid rgba(248, 246, 241, 0.25);
        box-shadow:
            inset 0 0 38px rgba(248, 246, 241, 0.12),
            0 16px 38px rgba(0, 0, 0, 0.28);
    }

    .orbit {
        position: absolute;
        border-radius: 50%;
        border: 1px dashed rgba(248, 246, 241, 0.35);
        inset: 0;
        animation: orbitSpin 16s linear infinite;
        animation-play-state: var(--hero-animation-play-state);
    }

    .orbit-middle {
        inset: 12%;
        animation-duration: 20s;
        animation-direction: reverse;
    }

    .orbit-inner {
        inset: 24%;
        animation-duration: 24s;
    }

    .scan {
        position: absolute;
        inset: 7%;
        border-radius: 50%;
        background: conic-gradient(
            from 220deg,
            transparent 0deg,
            rgba(203, 161, 53, 0.35) 36deg,
            transparent 100deg
        );
        animation: scanRotate 6s linear infinite;
        animation-play-state: var(--hero-animation-play-state);
    }

    .core {
        position: absolute;
        inset: 40%;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(203, 161, 53, 0.95), rgba(203, 161, 53, 0.15) 72%);
        box-shadow: 0 0 18px rgba(203, 161, 53, 0.7);
    }

    .node {
        position: absolute;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--ivory);
        box-shadow: 0 0 16px rgba(248, 246, 241, 0.75);
        animation: nodePulse 2.8s ease-in-out infinite;
        animation-play-state: var(--hero-animation-play-state);
    }

    .node-a {
        top: 17%;
        left: 63%;
    }

    .node-b {
        top: 60%;
        right: 16%;
        animation-delay: -1.15s;
    }

    .node-c {
        bottom: 21%;
        left: 21%;
        animation-delay: -0.5s;
    }

    .node-d {
        top: 46%;
        left: 13%;
        animation-delay: -1.7s;
    }

    .signal-panel {
        position: absolute;
        display: grid;
        gap: 0.22rem;
        min-width: min(56vw, 230px);
        max-width: 235px;
        padding: 0.72rem 0.85rem;
        border-radius: 0.72rem;
        background: rgba(248, 246, 241, 0.1);
        border: 1px solid rgba(248, 246, 241, 0.28);
        backdrop-filter: blur(8px);
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.25);
        animation: panelFloat 6.5s ease-in-out infinite;
        animation-play-state: var(--hero-animation-play-state);
    }

    .signal-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        opacity: 0.86;
    }

    .signal-panel strong {
        font-size: 0.93rem;
        line-height: 1.25;
    }

    .signal-one {
        top: 6%;
        left: -8%;
    }

    .signal-two {
        right: -4%;
        bottom: 3%;
        animation-delay: -3.2s;
    }

    .intel-feed {
        position: relative;
        z-index: 1;
        width: min(1120px, calc(100% - 2rem));
        margin: -1rem auto 0;
        padding-bottom: 1.2rem;
    }

    .intel-title {
        margin: 0 0 0.4rem;
        color: rgba(248, 246, 241, 0.9);
        font-size: 0.74rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .intel-track {
        overflow: hidden;
        border-radius: 0.68rem;
        border: 1px solid rgba(248, 246, 241, 0.22);
        background: rgba(1, 28, 17, 0.45);
        backdrop-filter: blur(8px);
        position: relative;
    }

    .intel-track::before,
    .intel-track::after {
        content: "";
        position: absolute;
        top: 0;
        bottom: 0;
        width: 58px;
        pointer-events: none;
        z-index: 1;
    }

    .intel-track::before {
        left: 0;
        background: linear-gradient(to right, rgba(1, 28, 17, 0.92), transparent);
    }

    .intel-track::after {
        right: 0;
        background: linear-gradient(to left, rgba(1, 28, 17, 0.92), transparent);
    }

    .intel-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        width: max-content;
        padding: 0.58rem 0.7rem;
        animation: tickerSlide 46s linear infinite;
        animation-play-state: var(--hero-animation-play-state);
    }

    .intel-track:hover .intel-row {
        animation-play-state: paused;
    }

    .intel-item {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: rgba(248, 246, 241, 0.92);
        text-decoration: none;
        white-space: nowrap;
        border: 1px solid rgba(248, 246, 241, 0.15);
        border-radius: 999px;
        padding: 0.42rem 0.74rem;
        background: rgba(248, 246, 241, 0.05);
        transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
        font-size: 0.83rem;
    }

    .intel-item::before {
        content: "";
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 50%;
        background: var(--gold-accent);
        box-shadow: 0 0 8px rgba(203, 161, 53, 0.8);
        animation: nodePulse 2.2s ease-in-out infinite;
        animation-play-state: var(--hero-animation-play-state);
    }

    .intel-item:hover {
        background: rgba(248, 246, 241, 0.16);
        border-color: rgba(248, 246, 241, 0.35);
        color: #fff;
    }

    .intel-date {
        font-size: 0.72rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: rgba(248, 246, 241, 0.72);
    }

    @media (max-width: 980px) {
        .hero-shell {
            grid-template-columns: 1fr;
            gap: 2rem;
            padding-top: 3.1rem;
            padding-bottom: 4.6rem;
            min-height: auto;
        }

        .hero-copy {
            max-width: 100%;
            transform: none;
            transition: none;
        }

        .hero-visual-wrap {
            justify-self: center;
            width: min(86vw, 420px);
            transform: none;
            transition: none;
        }

        .intel-feed {
            margin-top: 0.4rem;
        }
    }

    @media (max-width: 640px) {
        .hero-shell {
            width: min(100%, calc(100% - 1.2rem));
        }

        .hero-actions {
            width: 100%;
            flex-direction: column;
        }

        .cta {
            width: 100%;
        }

        .hero-tags {
            gap: 0.4rem;
        }

        .hero-tags li {
            font-size: 0.75rem;
        }

        .signal-panel {
            min-width: 170px;
            max-width: 190px;
            padding: 0.62rem 0.72rem;
        }

        .signal-one {
            left: -3%;
            top: 3%;
        }

        .signal-two {
            right: -2%;
            bottom: -2%;
        }

        .hero-metrics {
            display: grid;
            grid-template-columns: 1fr;
        }

        .metric {
            min-width: 0;
        }

        .intel-feed {
            width: min(100%, calc(100% - 1.2rem));
        }

        .intel-row {
            gap: 0.5rem;
            padding: 0.52rem;
        }

        .intel-item {
            font-size: 0.76rem;
            padding: 0.36rem 0.62rem;
        }

        .intel-date {
            display: none;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .hero *,
        .hero *::before,
        .hero *::after {
            animation: none !important;
            transition: none !important;
        }

        .hero-copy,
        .hero-visual-wrap {
            transform: none !important;
        }
    }

    @keyframes gridShift {
        from {
            background-position: 0 0, 0 0;
        }
        to {
            background-position: 44px 44px, 44px 44px;
        }
    }

    @keyframes auroraDrift {
        from {
            transform: translate3d(-12px, -10px, 0) scale(1);
        }
        to {
            transform: translate3d(14px, 16px, 0) scale(1.08);
        }

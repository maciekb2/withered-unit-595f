---
import type { TopicSummary } from '../utils/topics';
import FormattedDate from './FormattedDate.astro';
import Pagination from './Pagination.astro';
interface Props { topic: TopicSummary; page: number; perPage: number; }
const { topic, page, perPage } = Astro.props as Props;
const totalPages = Math.max(1, Math.ceil(topic.posts.length / perPage));
const currentPage = Math.min(Math.max(page, 1), totalPages);
const posts = topic.posts.slice((currentPage - 1) * perPage, currentPage * perPage);
const hrefForPage = (target: number) => target === 1 ? `/tematy/${topic.slug}/` : `/tematy/${topic.slug}/${target}/`;
---
<main class="dossier-page">
  <section class="dossier-hero" aria-labelledby="topic-title"><div><a href="/tematy/">← Wszystkie dossiers</a><p class="kicker">Obszar analizy</p><h1 id="topic-title">{topic.name}</h1><p>{topic.lens}</p></div><div class="dossier-stat"><strong>{topic.posts.length}</strong><span>materiałów w dossier</span></div></section>
  <div class="dossier-content"><section aria-label={`Materiały: ${topic.name}`}><p class="list-label">Materiały · strona {currentPage} z {totalPages}</p><ul class="dossier-list">{posts.map((post) => <li><a href={`/blog/${post.id}/`}><div>{post.data.heroImage && <img src={post.data.heroImage} alt="" loading="lazy" />}</div><article><time><FormattedDate date={post.data.pubDate} /></time><h2>{post.data.title}</h2><p>{post.data.description}</p></article></a></li>)}</ul><Pagination currentPage={currentPage} totalPages={totalPages} hrefForPage={hrefForPage} label={`Strony dossier ${topic.name}`} /></section><aside><p class="kicker">Perspektywa</p><h2>Co śledzimy</h2><p>{topic.context}</p><a href="/blog/">Przejdź do pełnego archiwum →</a></aside></div>
</main>
<style>
 .dossier-page{width:min(1120px,calc(100% - 2rem));max-width:none;padding:0 0 clamp(3rem,6vw,5rem);color:var(--ivory)}.dossier-hero{display:grid;grid-template-columns:minmax(0,1fr) 230px;gap:clamp(1.5rem,5vw,4rem);align-items:end;padding:clamp(3rem,7vw,5.5rem) 0 2.5rem;border-bottom:1px solid rgba(224,202,118,.2)}.dossier-hero>a,.dossier-hero div>a{display:inline-flex;margin-bottom:1.2rem;color:var(--gold-accent);font-size:.88rem;font-weight:700;text-decoration:none}.kicker{margin:0 0 .65rem;color:var(--gold-accent);font-size:.74rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase}.dossier-hero h1{margin:0;color:var(--ivory);font-size:clamp(2.8rem,6vw,5.2rem);line-height:.94}.dossier-hero>div>p:last-child{max-width:56ch;margin:1rem 0 0;color:rgba(241,238,229,.75);line-height:1.55}.dossier-stat{display:grid;gap:.35rem;padding:1.15rem;border:1px solid rgba(224,202,118,.22);background:rgba(3,29,22,.68)}.dossier-stat strong{font-size:clamp(2.5rem,5vw,4rem);line-height:1}.dossier-stat span{color:rgba(241,238,229,.65);font-size:.88rem}.dossier-content{display:grid;grid-template-columns:minmax(0,1fr) 270px;gap:clamp(1.5rem,4vw,3rem);padding-top:2rem}.list-label{margin:0 0 .8rem;color:rgba(241,238,229,.62);font-size:.83rem}.dossier-list{display:grid;gap:.8rem;margin:0;padding:0;list-style:none}.dossier-list a{display:grid;grid-template-columns:190px minmax(0,1fr);overflow:hidden;border:1px solid rgba(224,202,118,.18);color:inherit;background:rgba(7,43,33,.76);text-decoration:none}.dossier-list a>div{min-height:150px;background:#0b3329}.dossier-list img{display:block;width:100%;height:100%;object-fit:cover;filter:saturate(.84) contrast(1.04)}.dossier-list article{padding:1rem 1.1rem}.dossier-list time{color:var(--gold-accent);font-size:.74rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase}.dossier-list h2{margin:.45rem 0;color:var(--ivory);font-size:clamp(1.2rem,2vw,1.55rem);line-height:1.12}.dossier-list p{margin:0;color:rgba(241,238,229,.72);font-size:.92rem;line-height:1.5}.dossier-list a:hover,.dossier-list a:focus-visible{border-color:var(--gold-accent);box-shadow:0 14px 28px rgba(0,0,0,.22);outline:none}aside{align-self:start;position:sticky;top:104px;padding:1.1rem;border:1px solid rgba(224,202,118,.2);background:rgba(7,43,33,.76)}aside h2{margin:0;color:var(--ivory);font-size:1.35rem}aside p:not(.kicker){margin:.75rem 0 1rem;color:rgba(241,238,229,.72);font-size:.92rem;line-height:1.55}aside a{color:var(--gold-accent);font-size:.88rem;font-weight:700}@media(max-width:760px){.dossier-hero,.dossier-content{grid-template-columns:1fr}.dossier-content aside{position:static}.dossier-list a{grid-template-columns:1fr}.dossier-list a>div{aspect-ratio:3/2;min-height:0}}@media(max-width:520px){.dossier-page{width:min(100% - 1rem,1120px)}}
</style>

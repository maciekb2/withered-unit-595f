---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import PostNavigation from '../components/PostNavigation.astro';
import { SITE_TITLE } from '../consts';
import { inferTopicsForText, topicsFromTags } from '../utils/topics';

type Props = CollectionEntry<'blog'>['data'] & {
    slug: string;
    prev?: { id: string; data: { title: string } };
    next?: { id: string; data: { title: string } };
    related?: CollectionEntry<'blog'>[];
};

const {
    slug,
    title,
    description,
    pubDate,
    updatedDate,
    heroImage,
    sourceUrl,
    tags = [],
    likes,
    prev,
    next,
    related = [],
} = Astro.props as Props;

const sourceHost = sourceUrl
        ? new URL(sourceUrl).hostname.replace(/^www\./, '')
        : undefined;

const frontmatterTopics = topicsFromTags(tags);
const articleTopics = frontmatterTopics.length
        ? frontmatterTopics
        : inferTopicsForText(title, description);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      headline: title,
      description,
      keywords: articleTopics.map((topic) => topic.name),
      image: heroImage ? new URL(heroImage, Astro.site).toString() : undefined,
      url: new URL(`/blog/${slug}/`, Astro.site).toString(),
      datePublished: pubDate.toISOString(),
      dateModified: (updatedDate ?? pubDate).toISOString(),
      author: { "@type": "Organization", name: SITE_TITLE },
      publisher: { "@type": "Organization", name: SITE_TITLE },
      mainEntityOfPage: new URL(`/blog/${slug}/`, Astro.site).toString(),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: SITE_TITLE,
          item: new URL('/', Astro.site).toString(),
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Blog",
          item: new URL('/blog/', Astro.site).toString(),
        },
        {
          "@type": "ListItem",
          position: 3,
          name: title,
          item: new URL(`/blog/${slug}/`, Astro.site).toString(),
        },
      ],
    },
  ],
};

---

<html lang="pl">
        <head>
                <BaseHead title={title} description={description} image={heroImage} type="article" />
                <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
                <style>
                        main {
                                width: 100%;
                                max-width: 100%;
				margin: 0;
                                padding: 0 0 clamp(2rem, 4vw, 4rem);
			}
			.hero-image {
				width: 100%;
                                padding: clamp(0.75rem, 2vw, 1.5rem) 0;
                                background:
                                        linear-gradient(rgba(226, 206, 127, 0.045) 1px, transparent 1px),
                                        linear-gradient(90deg, rgba(226, 206, 127, 0.045) 1px, transparent 1px),
                                        #061d18;
                                background-size: 44px 44px;
			}
			.hero-image__frame {
				position: relative;
				width: min(1120px, calc(100% - 2rem));
				aspect-ratio: 3 / 2;
				max-height: min(72vh, 740px);
				margin: 0 auto;
				overflow: hidden;
				border: 1px solid rgba(226, 206, 127, 0.22);
				background: #0b2c23;
				box-shadow: 0 24px 64px rgba(2, 15, 12, 0.32);
			}
			.hero-image__frame::after {
				content: "";
				position: absolute;
				inset: 0;
				pointer-events: none;
				background:
					linear-gradient(180deg, rgba(3, 23, 18, 0.04), transparent 65%, rgba(3, 23, 18, 0.24)),
					linear-gradient(90deg, rgba(229, 211, 145, 0.08), transparent 14%, transparent 86%, rgba(229, 211, 145, 0.08));
			}
			.hero-image img {
				display: block;
                                width: 100%;
                                height: 100%;
                                object-fit: cover;
				border-radius: 0;
				filter: saturate(0.86) contrast(1.04);
			}
			.hero-image__label {
				position: absolute;
				top: 0.85rem;
				left: 0.85rem;
				z-index: 1;
				padding: 0.4rem 0.52rem;
				border: 1px solid rgba(242, 232, 190, 0.3);
				color: rgba(246, 239, 210, 0.86);
				background: rgba(4, 30, 23, 0.7);
				font-family: "Archivo Variable", "Atkinson", sans-serif;
				font-size: 0.58rem;
				font-weight: 680;
				letter-spacing: 0.14em;
				backdrop-filter: blur(8px);
			}
			.prose {
				width: min(760px, calc(100% - 2rem));
				margin: 0 auto;
				padding: clamp(1.4rem, 3vw, 2.4rem) 0 0;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: clamp(1.4rem, 4vw, 2.4rem);
				padding: clamp(1.2rem, 3vw, 2rem) 0 clamp(1rem, 2.6vw, 1.6rem);
				text-align: left;
				line-height: 1;
                                border-bottom: 1px solid rgba(28, 61, 90, 0.16);
			}
			.title h1 {
				margin: 0;
                                max-width: 16ch;
                                font-size: clamp(2.1rem, 5vw, 4rem);
                                line-height: 0.98;
                                letter-spacing: 0;
			}
                        .dek {
                                max-width: 64ch;
                                margin: 1rem 0 0;
                                color: rgba(var(--gray-dark), 0.82);
                                font-size: clamp(1rem, 1.8vw, 1.16rem);
                                line-height: 1.55;
                        }
			.article-meta {
				display: flex;
                                flex-wrap: wrap;
                                gap: 0.65rem;
                                align-items: center;
				margin-bottom: 1rem;
				color: rgba(var(--gray-dark), 0.76);
                                font-size: 0.9rem;
                                line-height: 1.3;
			}
                        .article-meta span,
                        .article-meta button,
                        .article-meta a {
                                display: inline-flex;
                                align-items: center;
                                min-height: 2rem;
                        }
                        .last-updated-on {
                                font-style: italic;
                        }
                        .metric {
                                gap: 0.32rem;
                                padding: 0.22rem 0.58rem;
                                border: 1px solid rgba(28, 61, 90, 0.14);
                                border-radius: 999px;
                                background: rgba(255, 255, 255, 0.6);
                        }
                        .like-control {
                                gap: 0.4rem;
                                border: 1px solid rgba(203, 161, 53, 0.38);
                                border-radius: 999px;
                                padding: 0.24rem 0.62rem;
                                color: var(--diplomatic-blue);
                                background: rgba(203, 161, 53, 0.12);
                                font: inherit;
                                font-size: 0.9rem;
                                line-height: 1.3;
                                cursor: pointer;
                                transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
                        }
                        .like-control:hover,
                        .like-control:focus-visible {
                                border-color: rgba(203, 161, 53, 0.78);
                                box-shadow: 0 8px 18px rgba(28, 61, 90, 0.12);
                                transform: translateY(-1px);
                                outline: none;
                        }
                        .like-control[disabled] {
                                cursor: default;
                                opacity: 0.78;
                                transform: none;
                        }
                        .source-link {
                                gap: 0.35rem;
                                padding: 0.22rem 0.58rem;
                                border: 1px solid rgba(28, 61, 90, 0.16);
                                border-radius: 999px;
                                color: var(--diplomatic-blue);
                                background: rgba(255, 255, 255, 0.62);
                                font-weight: 700;
                                text-decoration: none;
                        }
                        .source-link:hover,
                        .source-link:focus-visible {
                                border-color: rgba(203, 161, 53, 0.7);
                                outline: none;
                        }
                        .article-content {
                                font-size: clamp(1rem, 1.5vw, 1.08rem);
                        }
                        .article-content :global(h1:first-child) {
                                display: none;
                        }
                        .article-content :global(h1:first-child + p) {
                                display: none;
                        }
                        .article-content :global(h2) {
                                margin-top: 2.4rem;
                                padding-top: 1.2rem;
                                border-top: 1px solid rgba(28, 61, 90, 0.12);
                                font-size: clamp(1.75rem, 4vw, 2.35rem);
                        }
                        .article-content :global(p) {
                                margin: 0 0 1.45rem;
                        }
                        .topic-links {
                                display: flex;
                                flex-wrap: wrap;
                                gap: 0.55rem;
                                margin: -0.5rem 0 1.5rem;
                        }
                        .topic-links a {
                                display: inline-flex;
                                align-items: center;
                                min-height: 2rem;
                                padding: 0.28rem 0.62rem;
                                border: 1px solid rgba(28, 61, 90, 0.16);
                                border-radius: 999px;
                                color: var(--diplomatic-blue);
                                background: rgba(255, 255, 255, 0.68);
                                font-size: 0.84rem;
                                font-weight: 700;
                                text-decoration: none;
                                transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
                        }
                        .topic-links a:hover,
                        .topic-links a:focus-visible {
                                border-color: rgba(203, 161, 53, 0.7);
                                box-shadow: 0 8px 18px rgba(28, 61, 90, 0.1);
                                transform: translateY(-1px);
                                outline: none;
                        }
                        .article-next-step {
                                margin-top: clamp(2.5rem, 6vw, 4rem);
                                padding-top: 1.2rem;
                                border-top: 1px solid rgba(224, 202, 118, 0.24);
                        }
                        .article-next-step__header span {
                                display: block;
                                margin-bottom: 0.35rem;
                                color: var(--gold-accent);
                                font-size: 0.72rem;
                                font-weight: 700;
                                letter-spacing: 0.1em;
                                text-transform: uppercase;
                        }
                        .article-next-step__header h2 {
                                margin: 0;
                                color: var(--ivory);
                                font-size: clamp(1.45rem, 3vw, 2rem);
                                line-height: 1.1;
                        }
                        .related-posts {
                                margin: clamp(1.6rem, 4vw, 2.5rem) 0 1.5rem;
                                padding: clamp(1.15rem, 2vw, 1.5rem);
                                border: 1px solid rgba(224, 202, 118, 0.18);
                                border-radius: 14px;
                                background: rgba(7, 43, 33, 0.58);
                        }
                        .related-posts__header {
                                display: flex;
                                align-items: end;
                                justify-content: space-between;
                                gap: 1rem;
                                margin-bottom: 1rem;
                        }
                        .related-posts__eyebrow {
                                display: block;
                                margin-bottom: 0.35rem;
                                color: var(--gold-accent);
                                font-size: 0.72rem;
                                font-weight: 700;
                                letter-spacing: 0.1em;
                                text-transform: uppercase;
                        }
                        .related-posts h2 {
                                margin: 0;
                                color: var(--ivory);
                                font-size: clamp(1.45rem, 3vw, 2rem);
                                line-height: 1.1;
                        }
                        .related-posts__grid {
                                display: grid;
                                grid-template-columns: repeat(3, minmax(0, 1fr));
                                gap: 0.8rem;
                        }
                        .related-card {
                                display: grid;
                                grid-template-rows: auto 1fr;
                                overflow: hidden;
                                min-height: 100%;
                                color: inherit;
                                text-decoration: none;
                                border: 1px solid rgba(224, 202, 118, 0.16);
                                border-radius: 10px;
                                background: rgba(3, 29, 22, 0.7);
                                box-shadow: none;
                                transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
                        }
                        .related-card:hover,
                        .related-card:focus-visible {
                                transform: translateY(-3px);
                                border-color: rgba(203, 161, 53, 0.68);
                                box-shadow: 0 16px 32px rgba(28, 61, 90, 0.14);
                                outline: none;
                        }
                        .related-card img {
                                width: 100%;
                                aspect-ratio: 16 / 10;
                                object-fit: cover;
                                background: var(--dusty-beige);
                        }
                        .related-card__body {
                                display: grid;
                                gap: 0.45rem;
                                padding: 0.85rem;
                        }
                        .related-card__date {
                                color: var(--gold-accent);
                                font-size: 0.7rem;
                                font-weight: 700;
                                letter-spacing: 0.08em;
                                text-transform: uppercase;
                        }
                        .related-card h3 {
                                margin: 0;
                                color: var(--ivory);
                                font-size: 0.98rem;
                                line-height: 1.22;
                        }
                        .related-card p {
                                margin: 0;
                                color: rgba(241, 238, 229, 0.68);
                                font-size: 0.86rem;
                                line-height: 1.45;
                        }
                        @media (max-width: 680px) {
                                .hero-image {
                                        padding-top: 0;
                                        padding-bottom: 0;
                                }

                                .hero-image__frame {
                                        width: 100%;
                                        aspect-ratio: 4 / 3;
                                        max-height: 58vh;
                                        border-right: 0;
                                        border-left: 0;
                                }

                                .title h1 {
                                        max-width: 13ch;
                                }
                                .related-posts__grid {
                                        grid-template-columns: 1fr;
                                }
                        }
                </style>
	</head>

	<body data-page-section="article">
		<Header />
		<main>
			<article
                                data-article-page
                                data-article-slug={slug}
                                data-article-year={pubDate.getFullYear()}
                                data-article-age-days={Math.max(0, Math.floor((Date.now() - pubDate.getTime()) / 86400000))}
                        >
				{heroImage && (
					<div class="hero-image">
						<div class="hero-image__frame">
							<img width={1536} height={1024} src={heroImage} alt={title} />
							<span class="hero-image__label" aria-hidden="true">PI // ILUSTRACJA REDAKCYJNA</span>
						</div>
					</div>
				)}
				<div class="prose">
					<div class="title">
                                                <div class="article-meta" aria-label="Metadane artykułu">
                                                        <span><FormattedDate date={pubDate} /></span>
                                                        {
                                                                updatedDate && (
                                                                        <span class="last-updated-on">
                                                                               Ostatnia aktualizacja: <FormattedDate date={updatedDate} />
                                                                        </span>
                                                                )
                                                        }
                                                        <span class="metric">Wyświetlenia: <strong id="view-count">0</strong></span>
                                                        {sourceUrl && sourceHost && (
                                                                <a class="source-link" href={sourceUrl} target="_blank" rel="noreferrer">
                                                                        Źródło: {sourceHost} <span aria-hidden="true">↗</span>
                                                                </a>
                                                        )}
                                                        <button class="like-control" id="like-btn" type="button" aria-label="Polub wpis">
                                                                <span aria-hidden="true">♡</span>
                                                                <span>Polubienia: <strong id="like-count">{likes ?? 0}</strong></span>
                                                        </button>
                                                </div>
						<h1>{title}</h1>
                                                <p class="dek">{description}</p>
					</div>
                                        <nav class="topic-links" aria-label="Tematy artykułu">
                                                {articleTopics.map((topic) => (
                                                        <a href={`/tematy/${topic.slug}/`}>{topic.name}</a>
                                                ))}
                                        </nav>
                                        <div class="article-content">
                                                <slot />
                                        </div>
                                        <section class="article-next-step" aria-labelledby="article-next-step-title">
                                                <div class="article-next-step__header">
                                                        <span>Kontynuuj lekturę</span>
                                                        <h2 id="article-next-step-title">Przejdź do sąsiedniego tekstu</h2>
                                                </div>
                                                <PostNavigation prev={prev} next={next} />
                                        </section>
                                        {related.length > 0 && (
                                                <section class="related-posts" aria-labelledby="related-posts-title">
                                                        <div class="related-posts__header">
                                                                <div>
                                                                        <span class="related-posts__eyebrow">Czytaj dalej</span>
                                                                        <h2 id="related-posts-title">Powiązane teksty</h2>
                                                                </div>
                                                        </div>
                                                        <div class="related-posts__grid">
                                                                {related.map((post) => (
                                                                        <a
                                                                                class="related-card"
                                                                                href={`/blog/${post.id}/`}
                                                                                data-related-article
                                                                                data-related-slug={post.id}
                                                                        >
                                                                                {post.data.heroImage && (
                                                                                        <img src={post.data.heroImage} alt="" loading="lazy" />
                                                                                )}
                                                                                <div class="related-card__body">
                                                                                        <span class="related-card__date"><FormattedDate date={post.data.pubDate} /></span>
                                                                                        <h3>{post.data.title}</h3>
                                                                                        <p>{post.data.description}</p>
                                                                                </div>
                                                                        </a>
                                                                ))}
                                                        </div>
                                                </section>
                                        )}
                                </div>
                        </article>
                </main>
                <Footer />
                <script type="module" define:vars={{ slug }}>
                        const currentSlug = slug;
                        const article = document.querySelector('[data-article-page]');
                        const articleParams = {
                                article_slug: currentSlug,
                                article_year: Number(article?.dataset.articleYear || 0),
                                article_age_days: Number(article?.dataset.articleAgeDays || 0),
                        };
                        document.body.dataset.pageSection = 'article';
                        window.pseudointelektTrack?.('article_read_start', articleParams);

                        const scrollThresholds = [25, 50, 75, 90];
                        const seenThresholds = new Set();
                        let readCompleteSent = false;
                        function trackScrollDepth() {
                                const doc = document.documentElement;
                                const scrollable = doc.scrollHeight - window.innerHeight;
                                if (scrollable <= 0) return;
                                const percent = Math.min(100, Math.round((window.scrollY / scrollable) * 100));
                                scrollThresholds.forEach((threshold) => {
                                        if (percent >= threshold && !seenThresholds.has(threshold)) {
                                                seenThresholds.add(threshold);
                                                window.pseudointelektTrack?.('article_scroll_depth', {
                                                        ...articleParams,
                                                        scroll_percent: threshold,
                                                });
                                        }
                                });
                                if (percent >= 90 && !readCompleteSent) {
                                        readCompleteSent = true;
                                        window.pseudointelektTrack?.('article_read_complete', articleParams);
                                }
                        }
                        window.addEventListener('scroll', trackScrollDepth, { passive: true });
                        window.addEventListener('load', trackScrollDepth);

                        fetch(`/api/views/${currentSlug}`, { method: 'POST' })
                                .then((r) => r.ok ? r.json() : { views: 0 })
                                .then((d) => {
                                        const el = document.getElementById('view-count');
                                        if (el) el.textContent = d.views;
                                });
                        const likeBtn = document.getElementById('like-btn');
                        const likeStorageKey = `liked-${currentSlug}`;
                        fetch(`/api/likes?slugs=${currentSlug}`)
                                .then((r) => r.ok ? r.json() : {})
                                .then((d) => {
                                        const el = document.getElementById('like-count');
                                        if (el && d[currentSlug] != null) el.textContent = d[currentSlug];
                                        if (likeBtn && sessionStorage.getItem(likeStorageKey)) {
                                                likeBtn.disabled = true;
                                                const icon = likeBtn.querySelector('[aria-hidden="true"]');
                                                if (icon) icon.textContent = '♥';
                                                likeBtn.classList.add('liked');
                                        }
                                });
                        likeBtn?.addEventListener('click', () => {
                                fetch(`/api/likes/${currentSlug}`, { method: 'POST' })
                                        .then((r) => r.json().catch(() => ({})))
                                        .then((d) => {
                                                const el = document.getElementById('like-count');
                                                if (el && d.likes != null) el.textContent = d.likes;
                                                if (likeBtn) {
                                                        likeBtn.disabled = true;
                                                        const icon = likeBtn.querySelector('[aria-hidden="true"]');
                                                        if (icon) icon.textContent = '♥';
                                                        likeBtn.classList.add('liked', 'heartbeat');
                                                        likeBtn.addEventListener('animationend', () => {
                                                                likeBtn.classList.remove('heartbeat');
                                                        }, { once: true });
                                                }
                                                sessionStorage.setItem(likeStorageKey, '1');
                                                window.pseudointelektTrack?.('article_like', articleParams);
                                        });
                        });
                        document.querySelectorAll('.post-nav a').forEach((link) => {
                                link.addEventListener('click', () => {
                                        window.pseudointelektTrack?.('article_adjacent_click', {
                                                ...articleParams,
                                                direction: link.classList.contains('next') ? 'next' : 'prev',
                                        });
                                });
                        });
                        document.querySelectorAll('[data-related-article]').forEach((link) => {
                                link.addEventListener('click', () => {
                                        window.pseudointelektTrack?.('article_related_click', {
                                                ...articleParams,
                                                related_slug: link.dataset.relatedSlug || '',
                                        });
                                });
                        });
                </script>
        </body>
</html>

---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { buildTopicIndex, sortPostsByDate } from '../../utils/topics';

const posts = sortPostsByDate(await getCollection('blog'));
const topics = buildTopicIndex(posts);
const latestPost = posts[0];
---

<!doctype html>
<html lang="pl">
  <head>
    <BaseHead
      title={`Tematy | ${SITE_TITLE}`}
      description="Tematy i dossiers Pseudointelektu: geopolityka, polityka międzynarodowa, energia, technologia, Europa i gospodarka — z kontekstem oraz komentarzem."
    />
    <style>
      main {
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0;
      }
      .topics-hero {
        border-bottom: 1px solid rgba(var(--gray-dark), 0.12);
        background: var(--ivory);
        color: var(--charcoal);
      }
      .topics-hero__inner,
      .topics-grid,
      .latest-strip {
        width: min(1120px, calc(100% - 2rem));
        margin: 0 auto;
      }
      .topics-hero__inner {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(240px, 0.36fr);
        gap: clamp(1.5rem, 5vw, 4rem);
        align-items: end;
        padding: clamp(3rem, 7vw, 5.25rem) 0 clamp(2.1rem, 5vw, 3.4rem);
      }
      .kicker {
        margin: 0 0 0.75rem;
        color: var(--gold-accent);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.13em;
        text-transform: uppercase;
      }
      h1 {
        max-width: 12ch;
        margin: 0;
        font-size: clamp(2.4rem, 7vw, 5rem);
        line-height: 0.95;
        text-wrap: balance;
      }
      .topics-hero p {
        max-width: 62ch;
        margin: 1rem 0 0;
        color: rgba(var(--gray-dark), 0.84);
        font-size: clamp(1rem, 1.7vw, 1.16rem);
        line-height: 1.6;
      }
      .topics-stats {
        display: grid;
        gap: 0.75rem;
        padding: 1.1rem;
        border: 1px solid rgba(28, 61, 90, 0.14);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.68);
        box-shadow: 0 10px 24px rgba(28, 61, 90, 0.08);
      }
      .topics-stats strong {
        display: block;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1;
      }
      .topics-stats span {
        color: rgba(var(--gray-dark), 0.72);
      }
      .topics-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: clamp(0.9rem, 2vw, 1.25rem);
        padding: clamp(2.5rem, 5vw, 4rem) 0;
      }
      .topic-card {
        display: grid;
        grid-template-rows: auto 1fr auto;
        gap: 0.9rem;
        min-height: 100%;
        padding: clamp(1rem, 2vw, 1.35rem);
        color: inherit;
        text-decoration: none;
        border: 1px solid rgba(var(--gray-dark), 0.14);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.86);
        box-shadow: 0 8px 22px rgba(var(--gray-dark), 0.07);
        transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
      }
      .topic-card:hover,
      .topic-card:focus-visible {
        transform: translateY(-3px);
        border-color: rgba(203, 161, 53, 0.62);
        box-shadow: 0 16px 34px rgba(var(--gray-dark), 0.14);
        outline: none;
      }
      .topic-card__head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: start;
        padding-bottom: 0.85rem;
        border-bottom: 1px solid rgba(var(--gray-dark), 0.1);
      }
      .topic-card h2 {
        margin: 0;
        color: var(--charcoal);
        font-size: clamp(1.45rem, 2.7vw, 2rem);
        line-height: 1.1;
      }
      .topic-card__count {
        flex: 0 0 auto;
        min-width: 4.6rem;
        padding: 0.38rem 0.62rem;
        border-radius: 999px;
        background: rgba(203, 161, 53, 0.18);
        color: var(--accent-dark);
        font-size: 0.78rem;
        font-weight: 700;
        text-align: center;
      }
      .topic-card p {
        margin: 0;
        color: rgba(var(--gray-dark), 0.9);
        line-height: 1.55;
      }
      .topic-card__latest {
        display: grid;
        gap: 0.35rem;
        padding: 0.85rem;
        border: 1px solid rgba(var(--gray-dark), 0.1);
        border-radius: 8px;
        background: rgba(244, 239, 226, 0.58);
      }
      .topic-card__latest span {
        color: var(--diplomatic-blue);
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .topic-card__latest strong {
        color: var(--charcoal);
        line-height: 1.25;
      }
      .latest-strip {
        padding: 0 0 clamp(2.5rem, 5vw, 4rem);
        color: rgba(var(--gray-dark), 0.78);
      }
      .latest-strip a {
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        margin-left: 0.25rem;
        color: var(--diplomatic-blue);
        font-weight: 700;
        text-wrap: balance;
      }
      @media (max-width: 760px) {
        .topics-hero__inner,
        .topics-grid {
          grid-template-columns: 1fr;
        }
      }
      @media (max-width: 520px) {
        .topics-hero__inner,
        .topics-grid,
        .latest-strip {
          width: min(100%, calc(100% - 1.2rem));
        }
      }

      /* Situation Room: one clear editorial grid, no floating-card clutter. */
      .topics-hero {
        background: linear-gradient(180deg, rgba(7, 43, 33, 0.98), rgba(4, 32, 24, 0.96));
        color: var(--ivory);
        border-bottom-color: rgba(224, 202, 118, 0.22);
      }
      .topics-hero__inner { align-items: stretch; }
      .topics-hero p { color: rgba(241, 238, 229, 0.72); }
      .topics-stats {
        align-content: space-between;
        border-color: rgba(224, 202, 118, 0.24);
        border-radius: 0;
        background: rgba(3, 29, 22, 0.72);
        box-shadow: 0 16px 36px rgba(2, 20, 15, 0.24);
      }
      .topics-stats span { color: rgba(241, 238, 229, 0.65); }
      .topics-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.9rem;
        padding-top: clamp(1.5rem, 3vw, 2.25rem);
      }
      .topic-card {
        grid-column: auto;
        min-height: 0;
        padding: 1.15rem;
        border-color: rgba(224, 202, 118, 0.2);
        border-radius: 0;
        background: rgba(7, 43, 33, 0.72);
        box-shadow: 0 14px 30px rgba(2, 20, 15, 0.2);
      }
      .topic-card:nth-child(1), .topic-card:nth-child(4) { grid-column: auto; }
      .topic-card__head { border-bottom-color: rgba(224, 202, 118, 0.18); }
      .topic-card h2, .topic-card__latest strong { color: var(--ivory); }
      .topic-card p { color: rgba(241, 238, 229, 0.7); }
      .topic-card__count {
        background: rgba(217, 181, 62, 0.16);
        color: var(--gold-accent);
      }
      .topic-card__latest {
        border-color: rgba(224, 202, 118, 0.16);
        border-radius: 0;
        background: rgba(3, 29, 22, 0.7);
      }
      .topic-card__latest span, .latest-strip a { color: var(--gold-accent); }
      .topic-card__latest small { color: rgba(241, 238, 229, 0.55); }
      .latest-strip { color: rgba(241, 238, 229, 0.68); }
      @media (max-width: 900px) {
        .topics-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .topic-card, .topic-card:nth-child(1), .topic-card:nth-child(4) { grid-column: auto; }
      }
      @media (max-width: 600px) {
        .topics-grid { grid-template-columns: 1fr; }
        .topic-card, .topic-card:nth-child(1), .topic-card:nth-child(4) { grid-column: auto; }
      }
    </style>
  </head>
  <body data-page-section="topics">
    <Header />
    <main>
      <section class="topics-hero" aria-labelledby="topics-title">
        <div class="topics-hero__inner">
          <div>
            <p class="kicker">Dossiers redakcyjne</p>
            <h1 id="topics-title">Tematy, do których warto wracać</h1>
            <p>
              Zamiast porządku dat — pięć stałych perspektyw. Każda zbiera materiały,
              które opisują ten sam problem z kolejnych stron.
            </p>
          </div>
          <div class="topics-stats" aria-label="Statystyki tematów">
            <div>
              <strong>{posts.length}</strong>
              <span>materiały w archiwum</span>
            </div>
            <div>
              <strong>{topics.length}</strong>
              <span>obszarów analizy</span>
            </div>
          </div>
        </div>
      </section>

      <section class="topics-grid" aria-label="Lista tematów">
        {topics.map((topic) => {
          const latest = topic.posts[0];
          return (
            <a class="topic-card" href={`/tematy/${topic.slug}/`}>
              <div class="topic-card__head">
                <h2>{topic.name}</h2>
                <span class="topic-card__count">{topic.posts.length} wpisów</span>
              </div>
              <p>{topic.lens}</p>
              {latest && (
                <span class="topic-card__latest">
                  <span>Najnowszy materiał</span>
                  <strong>{latest.data.title}</strong>
                  <small><FormattedDate date={latest.data.pubDate} /></small>
                </span>
              )}
            </a>
          );
        })}
      </section>

      {latestPost && (
        <p class="latest-strip">
          Najnowsza analiza: <a href={`/blog/${latestPost.id}/`}>{latestPost.data.title}</a>
        </p>
      )}
    </main>
    <Footer />
  </body>
</html>

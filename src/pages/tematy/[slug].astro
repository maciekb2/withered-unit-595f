---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { buildTopicIndex, getTopicBySlug, sortPostsByDate } from '../../utils/topics';

export async function getStaticPaths() {
  const posts = sortPostsByDate(await getCollection('blog'));
  return buildTopicIndex(posts).map((topic) => ({
    params: { slug: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;
const topicDefinition = getTopicBySlug(topic.slug) ?? topic;
const latest = topic.posts[0];
const pageTitle = `${topicDefinition.name} | ${SITE_TITLE}`;
const pageDescription = `${topicDefinition.description} Najnowsze wpisy i powiązane komentarze z pseudointelekt.pl.`;
---

<!doctype html>
<html lang="pl">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <style>
      main {
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0;
      }
      .topic-hero {
        border-bottom: 1px solid rgba(var(--gray-dark), 0.12);
        background: var(--ivory);
        color: var(--charcoal);
      }
      .topic-hero__inner,
      .topic-content {
        width: min(1120px, calc(100% - 2rem));
        margin: 0 auto;
      }
      .topic-hero__inner {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(220px, 0.34fr);
        gap: clamp(1.5rem, 5vw, 4rem);
        align-items: end;
        padding: clamp(3rem, 7vw, 5.25rem) 0 clamp(2.1rem, 5vw, 3.4rem);
      }
      .back-link {
        display: inline-flex;
        align-items: center;
        min-height: 36px;
        margin-bottom: 1rem;
        color: var(--diplomatic-blue);
        font-weight: 700;
        text-decoration: none;
      }
      .back-link:hover {
        color: var(--accent-dark);
      }
      .kicker {
        margin: 0 0 0.75rem;
        color: var(--gold-accent);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.13em;
        text-transform: uppercase;
      }
      h1 {
        max-width: 13ch;
        margin: 0;
        font-size: clamp(2.4rem, 7vw, 5rem);
        line-height: 0.95;
        text-wrap: balance;
      }
      .topic-hero p {
        max-width: 64ch;
        margin: 1rem 0 0;
        color: rgba(var(--gray-dark), 0.84);
        font-size: clamp(1rem, 1.7vw, 1.16rem);
        line-height: 1.6;
      }
      .topic-stat {
        padding: 1.1rem;
        border: 1px solid rgba(28, 61, 90, 0.14);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.68);
        box-shadow: 0 10px 24px rgba(28, 61, 90, 0.08);
      }
      .topic-stat strong {
        display: block;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1;
      }
      .topic-stat span {
        color: rgba(var(--gray-dark), 0.72);
      }
      .topic-content {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(240px, 0.32fr);
        gap: clamp(1.4rem, 4vw, 3rem);
        align-items: start;
        padding: clamp(2.5rem, 5vw, 4rem) 0;
      }
      .post-list {
        display: grid;
        gap: clamp(0.9rem, 2vw, 1.2rem);
        margin: 0;
        padding: 0;
        list-style: none;
      }
      .post-card a {
        display: grid;
        grid-template-columns: minmax(160px, 0.34fr) minmax(0, 1fr);
        gap: 1rem;
        min-height: 100%;
        overflow: hidden;
        color: inherit;
        text-decoration: none;
        border: 1px solid rgba(var(--gray-dark), 0.14);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.88);
        box-shadow: 0 8px 22px rgba(var(--gray-dark), 0.07);
        transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
      }
      .post-card a:hover,
      .post-card a:focus-visible {
        transform: translateY(-3px);
        border-color: rgba(203, 161, 53, 0.62);
        box-shadow: 0 16px 34px rgba(var(--gray-dark), 0.14);
        outline: none;
      }
      .post-card img {
        width: 100%;
        height: 100%;
        min-height: 180px;
        object-fit: cover;
        background: var(--dusty-beige);
      }
      .post-card__body {
        display: grid;
        gap: 0.55rem;
        align-content: start;
        padding: 1rem 1rem 1rem 0;
      }
      .post-date {
        color: var(--diplomatic-blue);
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .post-card h2 {
        margin: 0;
        color: var(--charcoal);
        font-size: clamp(1.25rem, 2.6vw, 1.8rem);
        line-height: 1.12;
      }
      .post-card p {
        margin: 0;
        color: rgba(var(--gray-dark), 0.9);
        line-height: 1.55;
      }
      .topic-aside {
        position: sticky;
        top: 104px;
        display: grid;
        gap: 0.8rem;
        padding: 1rem;
        border: 1px solid rgba(var(--gray-dark), 0.14);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.82);
        box-shadow: 0 8px 22px rgba(var(--gray-dark), 0.06);
      }
      .topic-aside h2 {
        margin: 0;
        color: var(--charcoal);
        font-size: 1.1rem;
      }
      .topic-aside p {
        margin: 0;
        color: rgba(var(--gray-dark), 0.88);
        font-size: 0.94rem;
      }
      .topic-aside a {
        color: var(--diplomatic-blue);
        font-weight: 700;
      }
      @media (max-width: 860px) {
        .topic-hero__inner,
        .topic-content,
        .post-card a {
          grid-template-columns: 1fr;
        }
        .post-card__body {
          padding: 1rem;
        }
        .topic-aside {
          position: static;
        }
      }
      @media (max-width: 520px) {
        .topic-hero__inner,
        .topic-content {
          width: min(100%, calc(100% - 1.2rem));
        }
      }

      /* Topic detail uses the same dossier rhythm as the archive. */
      .topic-hero {
        background: linear-gradient(180deg, rgba(7, 43, 33, 0.98), rgba(4, 32, 24, 0.96));
        color: var(--ivory);
        border-bottom-color: rgba(224, 202, 118, 0.22);
      }
      .topic-hero p { color: rgba(241, 238, 229, 0.72); }
      .back-link { color: var(--gold-accent); }
      .back-link:hover { color: var(--ivory); }
      .topic-stat {
        border-color: rgba(224, 202, 118, 0.24);
        border-radius: 0;
        background: rgba(3, 29, 22, 0.72);
        box-shadow: 0 16px 36px rgba(2, 20, 15, 0.24);
      }
      .topic-stat span { color: rgba(241, 238, 229, 0.65); }
      .topic-content { grid-template-columns: minmax(0, 1fr) 280px; }
      .post-list { gap: 0.85rem; }
      .post-card a {
        grid-template-columns: 220px minmax(0, 1fr);
        border-color: rgba(224, 202, 118, 0.18);
        border-radius: 0;
        background: rgba(7, 43, 33, 0.72);
        box-shadow: 0 14px 30px rgba(2, 20, 15, 0.2);
      }
      .post-card img { min-height: 150px; }
      .post-card__body { padding: 1.1rem 1.2rem 1.1rem 0; }
      .post-date { color: var(--gold-accent); }
      .post-card h2 { color: var(--ivory); }
      .post-card p { color: rgba(241, 238, 229, 0.7); }
      .topic-aside {
        border-color: rgba(224, 202, 118, 0.2);
        border-radius: 0;
        background: rgba(7, 43, 33, 0.78);
        box-shadow: 0 14px 30px rgba(2, 20, 15, 0.2);
      }
      .topic-aside h2 { color: var(--gold-accent); }
      .topic-aside p { color: rgba(241, 238, 229, 0.7); }
      .topic-aside a { color: var(--gold-accent); }
      @media (max-width: 860px) {
        .post-card a { grid-template-columns: 180px minmax(0, 1fr); }
        .post-card__body { padding: 1rem 1rem 1rem 0; }
      }
    </style>
  </head>
  <body data-page-section="topic">
    <Header />
    <main>
      <section class="topic-hero" aria-labelledby="topic-title">
        <div class="topic-hero__inner">
          <div>
            <a class="back-link" href="/tematy/">← Wszystkie tematy</a>
            <p class="kicker">Temat</p>
            <h1 id="topic-title">{topicDefinition.name}</h1>
            <p>{topicDefinition.description}</p>
          </div>
          <div class="topic-stat" aria-label="Liczba wpisów w temacie">
            <strong>{topic.posts.length}</strong>
            <span>{topic.posts.length === 1 ? 'wpis' : 'wpisów'}</span>
          </div>
        </div>
      </section>

      <div class="topic-content">
        <section aria-label={`Wpisy w temacie ${topicDefinition.name}`}>
          <ul class="post-list">
            {topic.posts.map((post) => (
              <li class="post-card">
                <a href={`/blog/${post.id}/`}>
                  {post.data.heroImage && <img src={post.data.heroImage} alt="" loading="lazy" />}
                  <div class="post-card__body">
                    <span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
                    <h2>{post.data.title}</h2>
                    <p>{post.data.description}</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>

        <aside class="topic-aside" aria-label="Kontekst tematu">
          <h2>Po co ta ścieżka?</h2>
          <p>
            Stałe tematy pomagają wracać do podobnych wątków bez przeglądania całego archiwum.
            To także lepszy sygnał dla wyszukiwarki niż sama lista dat.
          </p>
          {latest && (
            <p>
              Najnowszy wpis w tej ścieżce: <a href={`/blog/${latest.id}/`}>{latest.data.title}</a>
            </p>
          )}
          <a href="/blog/">Przejdź do pełnego archiwum</a>
        </aside>
      </div>
    </main>
    <Footer />
  </body>
</html>

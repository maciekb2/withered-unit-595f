---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import TopicDossier from '../../components/TopicDossier.astro';
import { buildTopicIndex, sortPostsByDate } from '../../utils/topics';
export async function getStaticPaths() { const topics = buildTopicIndex(sortPostsByDate(await getCollection('blog'))); return topics.map((topic) => ({ params: { slug: topic.slug }, props: { topic } })); }
const { topic } = Astro.props;
---
<!doctype html><html lang="pl"><head><BaseHead title={`${topic.name} | Pseudointelekt`} description={topic.description} /></head><body data-page-section="topic"><Header /><TopicDossier topic={topic} page={1} perPage={20} /><Footer /></body></html>

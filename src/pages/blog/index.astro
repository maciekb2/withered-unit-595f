---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import BlogArchive from '../../components/BlogArchive.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf() || b.id.localeCompare(a.id));
---
<!doctype html><html lang="pl"><head><BaseHead title="Blog geopolityczny — analizy i komentarze | Pseudointelekt" description="Analizy geopolityki, gospodarki, technologii i mediów. Sprawdzamy decyzje, interesy oraz koszty, które zostają po nagłówkach." /></head><body data-page-section="archive"><Header /><BlogArchive posts={posts} page={1} perPage={20} /><Footer /></body></html>

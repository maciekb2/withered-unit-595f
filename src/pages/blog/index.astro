---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Sidebar from '../../components/Sidebar.astro';

// Sort posts so the newest ones appear first on the blog index
const posts = (await getCollection('blog')).sort((a, b) => {
  const dateDiff = b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  return dateDiff === 0 ? b.id.localeCompare(a.id) : dateDiff;
});

const [featuredPost, ...restPosts] = posts;
const latestYear = featuredPost?.data.pubDate.getFullYear();
---

<!doctype html>
<html lang="pl">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main.blog-page {
				color: var(--ivory);
				background: transparent;
			}

			main.blog-page {
				width: min(1180px, calc(100% - 2rem));
				max-width: none;
				padding: clamp(2rem, 4vw, 4rem) 0;
			}

			.blog-intro {
				display: grid;
				grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
				gap: clamp(1.5rem, 4vw, 3rem);
				align-items: end;
				margin-bottom: clamp(1.5rem, 4vw, 3rem);
				padding-bottom: 1.5rem;
				border-bottom: 1px solid rgba(224, 202, 118, 0.2);
			}

			.blog-intro h1 {
				color: var(--ivory);
				max-width: 10ch;
				margin: 0 0 0.55rem;
				font-size: clamp(2.4rem, 6vw, 5.2rem);
				letter-spacing: 0;
				line-height: 0.94;
			}

			.blog-intro p {
				max-width: 60ch;
				margin: 0;
				color: rgba(241, 238, 229, 0.72);
				font-size: clamp(1rem, 1.8vw, 1.18rem);
			}

			.blog-tools {
				display: grid;
				gap: 0.8rem;
				padding: 1rem;
				border: 1px solid rgba(224, 202, 118, 0.22);
				border-radius: 0;
				background: rgba(7, 43, 33, 0.78);
				box-shadow: 0 14px 34px rgba(2, 20, 15, 0.26);
			}

			.blog-tools label {
				display: grid;
				gap: 0.35rem;
				color: var(--gold-accent);
				font-size: 0.82rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}

			.blog-search {
				width: 100%;
				min-height: 46px;
				border: 1px solid rgba(224, 202, 118, 0.28);
				border-radius: 0;
				padding: 0.68rem 0.82rem;
				background: rgba(3, 29, 22, 0.84);
				color: var(--ivory);
				font: inherit;
				font-size: 1rem;
				line-height: 1.35;
				transition: border-color 160ms ease, box-shadow 160ms ease;
			}

			.blog-search:focus {
				outline: none;
				border-color: var(--gold-accent);
				box-shadow: 0 0 0 4px rgba(203, 161, 53, 0.18);
			}

			.blog-count {
				margin: 0;
				color: rgba(241, 238, 229, 0.68);
				font-size: 0.92rem;
				line-height: 1.35;
			}

			.featured {
				margin-bottom: clamp(1.8rem, 4vw, 3rem);
			}

			.featured-link {
				display: grid;
				grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
				gap: clamp(1rem, 3vw, 2rem);
				align-items: stretch;
				overflow: hidden;
				border: 1px solid rgba(224, 202, 118, 0.22);
				border-radius: 0;
				background: rgba(7, 43, 33, 0.82);
				color: inherit;
				text-decoration: none;
				box-shadow: 0 18px 42px rgba(28, 61, 90, 0.12);
				transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
			}

			.featured-link:hover,
			.featured-link:focus-visible {
				color: inherit;
				border-color: rgba(203, 161, 53, 0.56);
				box-shadow: 0 24px 54px rgba(28, 61, 90, 0.18);
				transform: translateY(-2px);
				outline: none;
			}

			.featured-media {
				position: relative;
				min-height: 0;
				aspect-ratio: 3 / 2;
				overflow: hidden;
				background: var(--diplomatic-blue);
			}

			.featured-media::after,
			.post-card-media::after {
				content: "";
				position: absolute;
				inset: 0;
				pointer-events: none;
				background: linear-gradient(180deg, transparent 58%, rgba(4, 30, 23, 0.28));
			}

			.featured-media img,
			.post-card-media img {
				display: block;
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				filter: saturate(0.86) contrast(1.04);
			}

			.featured-body {
				display: flex;
				flex-direction: column;
				justify-content: center;
				padding: clamp(1.2rem, 3vw, 2rem);
				min-width: 0;
			}

			.post-meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.55rem;
				align-items: center;
				margin: 0 0 0.85rem;
				color: rgba(var(--gray-dark), 0.7);
				font-size: 0.86rem;
				line-height: 1.3;
			}

			.post-meta span {
				display: inline-flex;
				align-items: center;
				min-height: 1.6rem;
			}

			.post-meta .marker {
				padding: 0.18rem 0.48rem;
				border: 1px solid rgba(203, 161, 53, 0.36);
				border-radius: 999px;
				color: var(--diplomatic-blue);
				background: rgba(203, 161, 53, 0.12);
				font-weight: 700;
			}

			.featured-title {
				color: var(--ivory);
				margin: 0 0 0.85rem;
				font-size: clamp(1.8rem, 4vw, 3rem);
				line-height: 1.04;
			}

			.featured-description,
			.post-description {
				margin: 0;
				color: rgba(241, 238, 229, 0.72);
				line-height: 1.55;
			}

			.layout {
				display: grid;
				grid-template-columns: minmax(0, 1fr) 300px;
				gap: clamp(1.5rem, 3vw, 2.25rem);
				align-items: start;
			}

			.post-list {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1.1rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.post-card {
				min-width: 0;
			}

			.post-card a {
				display: grid;
				grid-template-rows: auto 1fr;
				height: 100%;
				overflow: hidden;
				border: 1px solid rgba(224, 202, 118, 0.18);
				border-radius: 0;
				background: rgba(7, 43, 33, 0.72);
				color: inherit;
				text-decoration: none;
				transition: transform 170ms ease, box-shadow 170ms ease, border-color 170ms ease;
			}

			.post-card-media {
				position: relative;
				aspect-ratio: 3 / 2;
				overflow: hidden;
				background: var(--diplomatic-blue);
			}

			.post-card a:hover,
			.post-card a:focus-visible {
				color: inherit;
				border-color: rgba(203, 161, 53, 0.54);
				box-shadow: 0 16px 34px rgba(28, 61, 90, 0.13);
				transform: translateY(-2px);
				outline: none;
			}

			.post-card-body {
				display: grid;
				gap: 0.55rem;
				align-content: start;
				padding: 1rem;
			}

			.title { color: var(--ivory); }

			.title {
				margin: 0;
				color: rgb(var(--black));
				font-size: clamp(1.15rem, 2.1vw, 1.42rem);
				line-height: 1.12;
			}

			.post-description {
				display: -webkit-box;
				overflow: hidden;
				font-size: 0.94rem;
				-webkit-box-orient: vertical;
				-webkit-line-clamp: 3;
			}

			.empty-results {
				display: none;
				margin: 1rem 0 0;
				padding: 1rem;
				border: 1px dashed rgba(28, 61, 90, 0.26);
				border-radius: 8px;
				color: rgba(var(--gray-dark), 0.78);
				background: rgba(255, 255, 255, 0.48);
			}

			.empty-results.is-visible {
				display: block;
			}

			@media (max-width: 920px) {
				.blog-intro,
				.featured-link,
				.layout {
					grid-template-columns: 1fr;
				}

				.featured-media {
					min-height: 260px;
				}
			}

			@media (max-width: 640px) {
				main.blog-page {
					width: min(100% - 1rem, 1180px);
					padding-top: 1.2rem;
				}

				.blog-intro h1 {
					max-width: 11ch;
				}

				.post-list {
					grid-template-columns: 1fr;
				}

				.post-card a {
					grid-template-rows: 190px 1fr;
				}
			}
                </style>
	</head>
	<body data-page-section="archive">
		<Header />
                <main class="blog-page">
			<section class="blog-intro" aria-labelledby="blog-title">
				<div>
					<h1 id="blog-title">Kartoteka interesów</h1>
					<p>
						Porty, wybory, rakiety, surowce i publiczne miny. Wyszukaj temat,
						zanim kolejny nagłówek ogłosi, że wszystko zaczęło się dziś rano.
					</p>
				</div>
				<div class="blog-tools">
					<label for="blog-search">
						Szukaj w archiwum
						<input
							id="blog-search"
							class="blog-search"
							type="search"
							placeholder="Tytuł, opis albo temat"
							autocomplete="off"
						/>
					</label>
					<p class="blog-count" data-blog-count>
						{posts.length} wpisów{latestYear ? `, najnowszy z ${latestYear}` : ''}
					</p>
				</div>
			</section>

			{featuredPost && (
				<section
					class="featured"
					aria-label="Najnowszy wpis"
					data-search-card
					data-search={`${featuredPost.data.title} ${featuredPost.data.description}`.toLowerCase()}
				>
					<a class="featured-link" href={`/blog/${featuredPost.id}/`}>
						<div class="featured-media">
							{featuredPost.data.heroImage && (
								<img width={960} height={540} src={featuredPost.data.heroImage} alt="" loading="eager" />
							)}
						</div>
						<div class="featured-body">
							<p class="post-meta">
								<span class="marker">Ostatnia depesza</span>
								<span><FormattedDate date={featuredPost.data.pubDate} /></span>
							</p>
							<h2 class="featured-title">{featuredPost.data.title}</h2>
							<p class="featured-description">{featuredPost.data.description}</p>
						</div>
					</a>
				</section>
			)}

			<div class="layout">
				<section aria-label="Lista artykułów">
					<ul class="post-list" data-post-list>
						{
							restPosts.map((post) => (
								<li
									class="post-card"
									data-search-card
									data-search={`${post.data.title} ${post.data.description}`.toLowerCase()}
								>
									<a href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<div class="post-card-media">
												<img width={720} height={480} src={post.data.heroImage} alt="" loading="lazy" />
											</div>
										)}
										<div class="post-card-body">
											<p class="post-meta">
												<span><FormattedDate date={post.data.pubDate} /></span>
											</p>
											<h3 class="title">{post.data.title}</h3>
											<p class="post-description">{post.data.description}</p>
										</div>
									</a>
								</li>
							))
						}
					</ul>
					<p class="empty-results" data-empty-results>
						Nic tu nie pasuje do filtra. Spróbuj krótszego hasła albo innego tematu.
					</p>
				</section>
				<Sidebar />
			</div>
                </main>
               <Footer />
               <script type="module">
			document.body.dataset.pageSection = 'blog_archive';
			const search = document.querySelector('#blog-search');
			const cards = Array.from(document.querySelectorAll('[data-search-card]'));
			const count = document.querySelector('[data-blog-count]');
			const empty = document.querySelector('[data-empty-results]');
			const total = cards.length;
			let searchTrackTimer = 0;
			let lastTrackedSearch = '';

			function updateFilter() {
				const query = search instanceof HTMLInputElement
					? search.value.trim().toLowerCase()
					: '';
				let visible = 0;
				cards.forEach((card) => {
					const matches = !query || card.dataset.search?.includes(query);
					card.hidden = !matches;
					if (matches) visible += 1;
				});
				if (count) {
					const visibleTotal = query ? visible : total;
					count.textContent = `${visibleTotal} ${visibleTotal === 1 ? 'wpis' : 'wpisów'}${query ? ' pasuje do filtra' : ''}`;
				}
				if (empty) empty.classList.toggle('is-visible', query.length > 0 && visible === 0);
				window.clearTimeout(searchTrackTimer);
				if (query.length >= 2 && query !== lastTrackedSearch) {
					searchTrackTimer = window.setTimeout(() => {
						lastTrackedSearch = query;
						window.pseudointelektTrack?.('blog_search', {
							query_length: query.length,
							result_count: visible,
						});
					}, 650);
				}
			}

			search?.addEventListener('input', updateFilter);
               </script>
       </body>
</html>

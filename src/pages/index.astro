---
import BaseHead from '../components/BaseHead.astro';
import EditorialArchive from '../components/EditorialArchive.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SignalDashboard from '../components/SignalDashboard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import { buildTopicIndex } from '../utils/topics';

const posts = (await getCollection('blog')).sort((a, b) => {
    const dateDiff = b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
    return dateDiff === 0 ? b.id.localeCompare(a.id) : dateDiff;
});

const shortDateFormatter = new Intl.DateTimeFormat('pl-PL', {
    day: '2-digit',
    month: 'short',
});

const longDateFormatter = new Intl.DateTimeFormat('pl-PL', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
});

const latestHeadlines = posts.slice(0, 6).map((post) => ({
    title: post.data.title,
    href: `/blog/${post.id}/`,
    dateLabel: shortDateFormatter.format(post.data.pubDate),
}));

const toArticleCard = (post: (typeof posts)[number]) => ({
    title: post.data.title,
    description: post.data.description,
    href: `/blog/${post.id}/`,
    image: post.data.heroImage,
    dateLabel: longDateFormatter.format(post.data.pubDate),
});

const featuredArticle = posts[0] ? toArticleCard(posts[0]) : undefined;
const archiveArticles = posts.slice(1, 4).map(toArticleCard);
const topicHighlights = buildTopicIndex(posts).slice(0, 5).map((topic) => ({
    slug: topic.slug,
    name: topic.name,
    count: topic.posts.length,
    description: topic.description,
}));

const lastPublishedLabel = posts[0]
    ? longDateFormatter.format(posts[0].data.pubDate)
    : undefined;
---

<!doctype html>
<html lang="pl">
    <head>
        <BaseHead
            title={SITE_TITLE}
            description={SITE_DESCRIPTION}
            image={featuredArticle?.image}
        />
        <meta name="theme-color" content="#061d18" />
        <style>
            main.home-main {
                width: 100%;
                max-width: none;
                margin: 0;
                padding: 0;
            }

            .skip-link {
                position: fixed;
                top: 0.75rem;
                left: 0.75rem;
                z-index: 1000;
                padding: 0.65rem 0.85rem;
                color: #0b261e;
                background: #e2bd4d;
                text-decoration: none;
                transform: translateY(-160%);
                transition: transform 160ms ease;
            }

            .skip-link:focus {
                transform: translateY(0);
            }

            @media (prefers-reduced-motion: reduce) {
                .skip-link { transition: none; }
            }
        </style>
    </head>
    <body data-page-section="home">
        <a class="skip-link" href="#aktualny-sygnal">Przejdź do treści</a>
        <Header overlay />
        <main class="home-main">
            <Hero
                liveHeadlines={latestHeadlines}
                articleCount={posts.length}
                lastPublishedLabel={lastPublishedLabel}
            />
            <SignalDashboard
                featured={featuredArticle}
                topics={topicHighlights}
                headlines={latestHeadlines}
                articleCount={posts.length}
                lastPublishedLabel={lastPublishedLabel}
            />
            <EditorialArchive articles={archiveArticles} />
        </main>
        <Footer />
    </body>
</html>

---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { CONTACT_EMAIL } from '../consts';
---

<!doctype html>
<html lang="pl">
  <head>
    <BaseHead title="Kontakt" description="Napisz do Pseudointelektu" />
    <style>
      form {
        display: flex;
        flex-direction: column;
        gap: 0.5em;
        margin-top: 1em;
      }
      label {
        display: flex;
        flex-direction: column;
      }
      input, textarea {
        padding: 0.5em;
      }
      button {
        width: max-content;
        padding: 0.5em 1em;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>Kontakt</h1>
      <p>Masz temat, uwagę albo chcesz po prostu napisać? Wyślij wiadomość przez formularz albo bezpośrednio na <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>.</p>
      <form id="contact-form" action="/api/contact" method="post">
        <label>
          Imię lub podpis
          <input type="text" name="name" maxlength="120" required />
        </label>
        <label>
          Adres email
          <input type="email" name="email" maxlength="254" required />
        </label>
        <label>
          Wiadomość
          <textarea name="message" rows="5" maxlength="4000" required></textarea>
        </label>
        <button type="submit">Wyślij wiadomość</button>
      </form>
      <p id="status"></p>
    </main>
    <Footer />
    <script type="module">
      const form = document.getElementById('contact-form');
      const status = document.getElementById('status');
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const name = data.get('name').trim();
        const email = data.get('email').trim();
        const message = data.get('message').trim();
        if (!name) {
          status.textContent = 'Podaj imię albo podpis, żebym wiedział, do kogo odpisuję.';
          status.style.color = 'red';
          return;
        }
        if (!/^\S+@\S+\.\S+$/.test(email)) {
          status.textContent = 'Podaj poprawny adres email.';
          status.style.color = 'red';
          return;
        }
        if (!message) {
          status.textContent = 'Napisz chociaż kilka zdań, inaczej nie mam do czego się odnieść.';
          status.style.color = 'red';
          return;
        }
        const res = await fetch('/api/contact', { method: 'POST', body: data });
        if (res.ok) {
          status.textContent = 'Wiadomość wysłana. Dzięki.';
          status.style.color = 'green';
          form.reset();
        } else {
          status.textContent = 'Nie udało się wysłać wiadomości. Spróbuj ponownie za chwilę.';
          status.style.color = 'red';
        }
      });
    </script>
  </body>
</html>

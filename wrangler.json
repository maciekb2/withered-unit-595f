{
  "name": "pseudointelekt2137-blog",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./dist/worker.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": [
      "/generuj",
      "/generuj.html",
      "/api/*"
    ]
  },
  "kv_namespaces": [
    {
      "binding": "pseudointelekt_contact_form",
      "id": "b71f33f4cc0e48aaa96cf9aa53092882",
      "preview_id": "b71f33f4cc0e48aaa96cf9aa53092882"
    },
    {
      "binding": "pseudointelekt_views",
      "id": "0bdd1f5ed5e64d38877fa2dfc796b4ed",
      "preview_id": "0bdd1f5ed5e64d38877fa2dfc796b4ed"
    },
    {
      "binding": "pseudointelekt_likes",
      "id": "e22b4da9fe0e45d8ae2515792d5929df",
      "preview_id": "e22b4da9fe0e45d8ae2515792d5929df"
    }
  ],
  "d1_databases": [
    {
      "binding": "pseudointelekt_logs_db",
      "database_name": "pseudointelekt_logs",
      "database_id": "c290edf1-394f-4c8b-940c-da62db2774b1"
    }
  ],
  "vars": {
    "WORKER_ID": "pseudointelekt2137-blog",
    "OPENAI_TEXT_MODEL": "gpt-5",
    "OPENAI_TOPIC_MODEL": "",
    "OPENAI_OUTLINE_MODEL": "",
    "OPENAI_DRAFT_MODEL": "",
    "OPENAI_EDIT_MODEL": "",
    "OPENAI_REPAIR_MODEL": "",
    "OPENAI_IMAGE_MODEL": "gpt-image-1.5",
    "OPENAI_IMAGE_SIZE": "1024x1024",
    "OPENAI_IMAGE_STYLE": "vivid",
    "OPENAI_IMAGE_QUALITY": "medium",
    "TEXT_GENERATION_PROVIDER": "openai",
    "TEXT_GENERATION_FALLBACK": "openai",
    "TEXT_ARTICLE_PIPELINE": "auto",
    "TEXT_SECTION_PARAGRAPHS": "3",
    "TEXT_SECTION_MAX_TOKENS": "1800",
    "JETSON_GATEWAY_MODEL": "qwen3:4b",
    "JETSON_GATEWAY_TIMEOUT_MS": "120000",
    "JETSON_GATEWAY_DISABLE_THINKING": "true"
  },
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "triggers": {
    "crons": ["0 10 * * *"]
  }
}
